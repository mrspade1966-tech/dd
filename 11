    return &quot;\n&quot;.join(lines) if lines else &quot;Haber bulunamadı.&quot;</code></pre></div></div></pre><h3>Adım 2.4: Risk Yönetimi Modülü (<code class="rounded px-1.5 py-0.5 bg-surface-tertiary font-mono text-[0.9em] text-text-primary font-medium" node="[object Object]">core/modules/risk_manager.py</code>)</h3><p><code class="rounded px-1.5 py-0.5 bg-surface-tertiary font-mono text-[0.9em] text-text-primary font-medium" node="[object Object]">bot.py</code>&#x27;deki <code class="rounded px-1.5 py-0.5 bg-surface-tertiary font-mono text-[0.9em] text-text-primary font-medium" node="[object Object]">/karzarar</code> komutunun tüm modları (trade hesabı, risk, pozisyon boyutu) buraya fonksiyon olarak taşınacak.</p><pre><div class="not-prose my-0 flex w-full flex-col overflow-clip border border-border text-text-primary rounded-lg not-prose relative" data-code-block="true"><div class="border-border flex items-center justify-between border-b px-4 py-2"><div class="flex items-center gap-2"><svg width="14" stroke-width="1.5" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-text-secondary"><path d="M9.00001 21L8.00001 21C6.89544 21 6.00001 20.1057 6.00001 19.0011C6.00001 17.4501 6.00001 15.3443 6 14C6 13 4.5 12 4.5 12C4.5 12 6.00001 11 6.00001 10C6.00001 8.827 6.00001 6.62207 6.00001 4.99914C6.00001 3.89457 6.89544 3 8.00001 3L9.00001 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 21L16 21C17.1046 21 18 20.1057 18 19.0011C18 17.4501 18 15.3443 18 14C18 13 19.5 12 19.5 12C19.5 12 18 11 18 10C18 8.827 18 6.62207 18 4.99914C18 3.89457 17.1046 3 16 3L15 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><span class="text-text-secondary text-sm font-medium">Python</span></div><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring ring-offset-2 focus-visible:ring-offset-surface-primary disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 text-sm text-interactive-active hover:text-interactive-normal active:text-text-tertiary font-normal relative rounded-lg p-[6px]" type="button" data-state="closed" data-slot="tooltip-trigger"><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-interactive-positive absolute inset-0 m-auto rotate-90 opacity-0 transition-all duration-300"><path d="M5 13L9 17L19 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="absolute inset-0 m-auto opacity-100 transition-opacity duration-300"><path d="M19.4 20H9.6C9.26863 20 9 19.7314 9 19.4V9.6C9 9.26863 9.26863 9 9.6 9H19.4C19.7314 9 20 9.26863 20 9.6V19.4C20 19.7314 19.7314 20 19.4 20Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 9V4.6C15 4.26863 14.7314 4 14.4 4H4.6C4.26863 4 4 4.26863 4 4.6V14.4C4 14.7314 4.26863 15 4.6 15H9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg></button></div><div class="code-block_container__lbMX4"><pre class="m-0 whitespace-pre-wrap rounded-none px-4 py-3 font-mono text-[#24292e] dark:text-[#e1e4e8]"><code class="text-[11px] leading-normal sm:text-[13px]"># trading_ai_system/core/modules/risk_manager.py

from loguru import logger

def calculate_trade_pnl(alis: float, satis: float, adet: float) -&gt; dict:
    &quot;&quot;&quot;Bir trade&#x27;in kar/zararını hesaplar.&quot;&quot;&quot;
    if not all([alis &gt; 0, satis &gt; 0, adet &gt; 0]):
        return {&quot;error&quot;: &quot;Tüm değerler sıfırdan büyük olmalı.&quot;}
        
    alis_top = alis * adet
    satis_top = satis * adet
    kaz_tl = satis_top - alis_top
    kaz_pct = (satis - alis) / alis
    komisyon = (alis_top + satis_top) * 0.001 # Ortalama %0.1 komisyon varsayımı
    net_kaz = kaz_tl - komisyon
    
    return {
        &quot;alis_top&quot;: alis_top,
        &quot;satis_top&quot;: satis_top,
        &quot;kaz_tl&quot;: kaz_tl,
        &quot;kaz_pct&quot;: kaz_pct,
        &quot;komisyon&quot;: komisyon,
        &quot;net_kaz&quot;: net_kaz,
        &quot;yon&quot;: &quot;KÂR&quot; if kaz_tl &gt;= 0 else &quot;ZARAR&quot;
    }

def calculate_position_size(portfolio: float, risk_pct: float, giris: float, stop: float) -&gt; dict:
    &quot;&quot;&quot;Verilen risk parametrelerine göre ideal pozisyon boyutunu hesaplar.&quot;&quot;&quot;
    if not all([portfolio &gt; 0, risk_pct &gt; 0, giris &gt; stop &gt; 0]):
        return {&quot;error&quot;: &quot;Geçersiz parametreler.&quot;}
    
    risk_pct_decimal = risk_pct / 100
    max_risk_amount = portfolio * risk_pct_decimal
    risk_per_share = giris - stop
    
    if risk_per_share &lt;= 0:
        return {&quot;error&quot;: &quot;Giriş fiyatı stop&#x27;tan büyük olmalı.&quot;}
        
    adet = max_risk_amount / risk_per_share
    pozisyon_degeri = adet * giris
    
    return {
        &quot;max_risk_amount&quot;: max_risk_amount,
        &quot;risk_per_share&quot;: risk_per_share,
        &quot;adet&quot;: adet,
        &quot;pozisyon_degeri&quot;: pozisyon_degeri,
        &quot;portfoy_yuzdesi&quot;: (pozisyon_degeri / portfolio) * 100,
        &quot;hedef1&quot;: giris + (risk_per_share * 2), # 1:2 R/R
        &quot;hedef2&quot;: giris + (risk_per_share * 3), # 1:3 R/R
    }

def analyze_open_position(alis: float, adet: float, guncel: float) -&gt; dict:
    &quot;&quot;&quot;Açık bir pozisyonun anlık kar/zarar durumunu hesaplar.&quot;&quot;&quot;
    if not all([alis &gt; 0, adet &gt; 0, guncel &gt; 0]):
        return {&quot;error&quot;: &quot;Tüm değerler sıfırdan büyük olmalı.&quot;}
        
    kaz_tl = (guncel - alis) * adet
    kaz_pct = (guncel - alis) / alis
    
    return {
        &quot;kaz_tl&quot;: kaz_tl,
        &quot;kaz_pct&quot;: kaz_pct,
        &quot;yon&quot;: &quot;KÂR&quot; if kaz_tl &gt;= 0 else &quot;ZARAR&quot;,
        &quot;stop&quot;: alis * 0.97, # %3 örnek stop
        &quot;hedef1&quot;: alis * 1.10, # %10 örnek hedef
        &quot;hedef2&quot;: alis * 1.20, # %20 örnek hedef
    }</code></pre></div></div></pre><hr/><h2>SONRAKİ ADIMLAR</h2><ol>
