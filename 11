ntrading_ai_system/\n│\n├── config/\n│   ├── settings.py          # Tüm ayarlar buradan\n│   └── api_keys.env         # Git'e gitmiyor\n│\n├── core/\n│   ├── scanner.py           # tara_indicators + stratejiler + Spade\n│   ├── news.py              # RSS + KAP\n│   ├── risk.py              # ATR stop/hedef + gap + MTF skor\n│   └── data.py              # Yahoo çekim + cache\n│\n├── agents/\n│   ├── base.py              # Ortak yapı\n│   ├── ceo.py               # Sabah brifing + sentez\n│   ├── scanner_agent.py     # Tarama yorumu\n│   ├── news_agent.py        # Haber yorumu\n│   ├── strategy_agent.py    # YENİ strateji üretici\n│   └── prompts/             # Skill dosyaları\n│       ├── ceo.txt\n│       ├── scanner.txt\n│       ├── news.txt\n│       └── strategy.txt\n│\n├── memory/\n│   └── db.py                # PostgreSQL - tüm hafıza buradan\n│\n├── bot/\n│   └── telegram.py          # Tek giriş noktası\n│\n├── scheduler.py             # APScheduler - zamanlanmış görevler\n├── main.py                  # Başlatıcı\n└── requirements.txt\n```\n\n---\n\n## 🗄️ Veritabanı Şeması (Sıfırdan)\n\nEski bot.py'deki `store` tablosu yerine gerçek tablolar:\n\n```sql\n-- 1. FİYAT CACHE (bot.py'den taşınıyor, aynı mantık)\nCREATE TABLE price_cache (\n    ticker      TEXT PRIMARY KEY,\n    fetched_at  DATE NOT NULL,\n    data        TEXT NOT NULL\n);\n\n-- 2. WATCHLIST (bot.py'den taşınıyor)\nCREATE TABLE watchlist (\n    chat_id     TEXT NOT NULL,\n    ticker      TEXT NOT NULL,\n    added_at    TIMESTAMP DEFAULT NOW(),\n    PRIMARY KEY (chat_id, ticker)\n);\n\n-- 3. EMA OPTİMİZASYON (bot.py'den taşınıyor)\nCREATE TABLE ema_settings (\n    ticker      TEXT PRIMARY KEY,\n    daily_fast  INT DEFAULT 9,\n    daily_slow  INT DEFAULT 21,\n    weekly_fast INT DEFAULT 9,\n    weekly_slow INT DEFAULT 21,\n    updated_at  TIMESTAMP DEFAULT NOW()\n);\n\n-- 4. TARAMA SONUÇLARI (YENİ - öğrenme için kritik)\nCREATE TABLE scan_results (\n    id              SERIAL PRIMARY KEY,\n    scan_date       DATE NOT NULL,\n    chat_id         TEXT NOT NULL,\n    strategy_code   TEXT NOT NULL,\n    ticker          TEXT NOT NULL,\n    price           FLOAT,\n    rsi             FLOAT,\n    rel_vol         FLOAT,\n    composite       FLOAT,\n    ai_comment      TEXT,\n    -- Sonuç takibi (başta NULL, sonra doldurulur)\n    ret_1d          FLOAT,\n    ret_5d          FLOAT,\n    ret_21d         FLOAT,\n    outcome_filled  BOOLEAN DEFAULT FALSE,\n    created_at      TIMESTAMP DEFAULT NOW()\n);\n\n-- 5. TRADE KİTABI (bot.py'den taşınıyor + genişletiliyor)\nCREATE TABLE trades (\n    id              SERIAL PRIMARY KEY,\n    chat_id         TEXT NOT NULL,\n    ticker          TEXT NOT NULL,\n    direction       TEXT NOT NULL,  -- BUY / SELL\n    price           FLOAT NOT NULL,\n    quantity        FLOAT NOT NULL,\n    total           FLOAT NOT NULL,\n    reason          TEXT,           -- Kullanıcının neden aldığı\n    strategy_ref    TEXT,           -- Hangi strateji sinyali verdi\n    trade_date      TIMESTAMP DEFAULT NOW(),\n    -- Satış için\n    buy_price       FLOAT,          -- Eşleşen alış fiyatı\n    pnl_tl          FLOAT,\n    pnl_pct         FLOAT,\n    hold_days       INT,\n    ai_review       TEXT,           -- AI'ın satış yorumu\n    created_at      TIMESTAMP DEFAULT NOW()\n);\n\n-- 6. AÇIK POZİSYONLAR (bot.py'den taşınıyor)\nCREATE TABLE open_positions (\n    chat_id         TEXT NOT NULL,\n    ticker          TEXT PRIMARY KEY,\n    avg_price       FLOAT NOT NULL,\n    quantity        FLOAT NOT NULL,\n    reason          TEXT,\n    opened_at       TIMESTAMP DEFAULT NOW(),\n    updated_at      TIMESTAMP DEFAULT NOW()\n);\n\n-- 7. AGENT KARARLARI (YENİ - hafıza)\nCREATE TABLE agent_decisions (\n    id              SERIAL PRIMARY KEY,\n    agent_name      TEXT NOT NULL,\n    decision_type   TEXT NOT NULL,\n    context         JSONB,\n    decision        TEXT NOT NULL,\n    confidence      FLOAT,\n    created_at      TIMESTAMP DEFAULT NOW()\n);\n\n-- 8. PİYASA BAĞLAMI (YENİ - dinamik skill için)\nCREATE TABLE market_context (\n    id              SERIAL PRIMARY KEY,\n    context_date    DATE UNIQUE NOT NULL,\n    regime          TEXT,\n    xu100_change    FLOAT,\n    usdtry          FLOAT,\n    top_sectors     JSONB,\n    key_news        TEXT,\n    created_at      TIMESTAMP DEFAULT NOW()\n);\n\n-- 9. ÖĞRENİLEN DERSLER (YENİ - strategy agent için)\nCREATE TABLE lessons (\n    id              SERIAL PRIMARY KEY,\n    lesson_date     DATE NOT NULL,\n    source          TEXT,       -- hangi agent/strateji\n    category        TEXT,       -- PATTERN, STRATEGY, RISK\n    lesson          TEXT NOT NULL,\n    evidence        JSONB,\n    importance      INT DEFAULT 5,\n    is_active       BOOLEAN DEFAULT TRUE,\n    created_at      TIMESTAMP DEFAULT NOW()\n);\n```\n\n---\n\n## 🤖 Agent Skill Dosyaları (Yazacağım şeyler)\n\n```\nCEO Agent Skill:\n\"Sen bir portföy yöneticisisin. Sabah toplantısını sen\nyönetirsin. Scanner ve News Agent'ten gelen raporları \nsentezler, çelişkileri bulur, kullanıcıya net eylem planı\nsunarsın. BIST dinamiklerini, Türk ekonomisini ve \nyatırımcının açık pozisyonlarını bilirsin.\"\n\nScanner Agent Skill:\n\"Sen bir quant analistisin. Ham tarama verilerini \nyorumlarsın. Sayıları hikayeye çevirirsin. Hangi\nsinyalin gerçek, hangisinin gürültü olduğunu ayırt\nedersin.\"\n\nNews Agent Skill:\n\"Sen bir piyasa araştırma analistisin. Haberlerin\nBIST üzerindeki etkisini değerlendirirsin. KAP \nbildirimleri, makro gelişmeler ve sektör haberleri\narasında önceliklendirme yaparsın.\"\n\nStrategy Agent Skill:\n\"Sen bir sistemli trading stratejisti ve quant\naraştırmacısısın. Geçmiş sinyal performanslarını\nanaliz edip yeni, test edilebilir strateji hipotezleri\nüretirsin.\"\n```\n\n---\n\n## 📅 Kurulum Sırası (Oracle Cloud'da)\n\n```\nADIM 1: Oracle Cloud hazırlık (15 dk)\n├── Python 3.11 + venv\n├── PostgreSQL (zaten varsa skip)\n└── requirements.txt\n\nADIM 2: Veritabanı kurulumu (10 dk)\n├── Tabloları oluştur