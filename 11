from __future__ import annotations

from datetime import datetime, date
from loguru import logger
from core.modules.database import db, AgentDecision, LessonLearned, MarketContext

class AgentMemory:
    def log_decision(self, agent_name: str, decision_type: str, decision: str,
                     context: dict | None = None, confidence: float | None = None):
        s = db.session()
        try:
            rec = AgentDecision(
                agent_name=agent_name,
                decision_type=decision_type,
                decision=decision,
                context=context or {},
                confidence=confidence
            )
            s.add(rec)
            s.commit()
        except Exception as e:
            s.rollback()
            logger.error(f&quot;AgentDecision kayıt hatası: {e}&quot;)
        finally:
            s.close()

    def get_active_lessons(self, limit: int = 10, category: str | None = None):
        s = db.session()
        try:
            q = s.query(LessonLearned).filter(LessonLearned.is_active == True)  # noqa
            if category:
                q = q.filter(LessonLearned.category == category)
            return q.order_by(LessonLearned.importance.desc()).limit(limit).all()
        finally:
            s.close()

    def upsert_market_context(self, context_date: date, regime: str | None = None,
                              key_news_summary: str | None = None):
        s = db.session()
        try:
            rec = s.query(MarketContext).filter(MarketContext.context_date == context_date).first()
            if rec is None:
                rec = MarketContext(context_date=context_date, regime=regime, key_news_summary=key_news_summary)
                s.add(rec)
            else:
                if regime is not None:
                    rec.regime = regime
                if key_news_summary is not None:
                    rec.key_news_summary = key_news_summary
            s.commit()
        except Exception as e:
            s.rollback()
            logger.error(f&quot;MarketContext upsert hatası: {e}&quot;)
        finally:
            s.close()

