\"\nBIST Tarama Motoru.\nTeknik indikatör hesaplama, strateji filtreleri ve SpadeHunter.\nTelegram bağımlılığı YOKTUR. Sadece saf hesaplama.\n\nbot.py'den taşınan fonksiyonlar:\n- calc_rsi, calc_ema, calc_sma, calc_macd, calc_adx, calc_atr\n- calc_bollinger_width, calc_mtf_score, detect_divergence\n- detect_market_regime, calc_signal_confidence\n- calc_volume_momentum, calc_gap_analysis, calc_risk_management\n- tara_indicators, strateji_filtre, spade_indicators\n- backtest_strategy\n\"\"\"\n\nimport time\nimport numpy as np\nimport pandas as pd\nimport pytz\nimport requests\nfrom datetime import datetime\nfrom loguru import logger\n\n\n# ============================================================\n# SABITLER\n# ============================================================\n\nSPADE_BUY_LIMIT = 0\nSPADE_VOL_MULT = 1.8\nSPADE_VOL_EARLY = 1.3\nSPADE_ADX_THRESH = 25\nSPADE_RSI_LOWER = 40\nSPADE_RSI_UPPER = 68\nSPADE_M1 = 5\nSPADE_M2 = 5\n\nTD_DELAY = 1.5  # Yahoo Finance istek gecikmesi\n\n# Strateji tanımları\nTARA_STRATEJILER = {\n    \"1\":  (\"🧠 Smart Money Birikim\",     \"Patlama öncesi sessiz birikim\"),\n    \"2\":  (\"📈 Düşen Trend Kırılımı\",    \"Yeni yükseliş başlangıcı\"),\n    \"3\":  (\"🔄 Güçlü Dipten Dönüş\",     \"Destekten güçlü RSI dönüşü\"),\n    \"4\":  (\"🚀 Momentum Patlaması\",      \"Sert yükseliş — hacim+RSI+MACD\"),\n    \"6\":  (\"🔥 Tavan Serisi\",            \"Ardışık tavan yapabilecek hisseler\"),\n    \"7\":  (\"💎 Akümülasyon Çıkışı\",     \"Büyük hareket başlangıcı\"),\n    \"8\":  (\"🌱 Erken Trend Doğumu\",     \"Trend başlıyor, SMA dizilimi oluştu\"),\n    \"9\":  (\"🏦 Kurumsal Para Girişi\",   \"Gizli kurumsal toplama\"),\n    \"10\": (\"⚖️ Güçlü Konsolidasyon\",   \"Sıkışma — yakında büyük hareket\"),\n    \"11\": (\"⚡ Volatilite Patlaması\",   \"Ani hacim + fiyat hareketi\"),\n    \"12\": (\"👑 Sektör Lideri\",          \"Güçlü hisseler — trend liderliği\"),\n    \"13\": (\"🌅 Dipten Lider Doğuşu\",   \"Derin düşüşten güçlü dönüş\"),\n    \"14\": (\"💰 Büyük Ralli\",            \"+%50 potansiyel — tüm göstergeler uyumlu\"),\n    \"A\":  (\"💪 Piyasadan Güçlü\",       \"Relative strength — endeksten üstün\"),\n    \"B\":  (\"💸 Büyük Para Girişi\",     \"Günlük trade fırsatı\"),\n    \"C\":  (\"🛡️ Endeks Düşerken Güçlü\", \"Düşen piyasada ayakta\"),\n    \"15\": (\"📊 Bilançodan Önce Hareket\",\"Güçlü büyüme + teknik uyum\"),\n    \"16\": (\"🎯 Baz Kırılımı\",          \"3ay yatay/düşen + EMA dizilimi + hacim artışı\"),\n}\n\n# Strateji → rejim tipi eşleşmesi\nSTRATEJI_REJIM_TIPI = {\n    \"1\": \"squeeze\",  \"2\": \"breakout\", \"3\": \"mean_rev\", \"4\": \"momentum\",\n    \"6\": \"momentum\", \"7\": \"breakout\", \"8\": \"breakout\", \"9\": \"squeeze\",\n    \"10\": \"squeeze\", \"11\": \"momentum\",\"12\": \"momentum\",\"13\": \"mean_rev\",\n    \"14\": \"momentum\",\"A\": \"momentum\", \"B\": \"momentum\", \"C\": \"mean_rev\",\n    \"15\": \"breakout\",\"16\": \"breakout\",\n}\n\n\n# ============================================================\n# VERİ ÇEKME\n# ============================================================\n\ndef fetch_yahoo_direct(ticker: str, interval: str = \"1d\",\n                       range_: str = \"2y\") -\u003e pd.DataFrame:\n    \"\"\"Yahoo Finance'den OHLCV verisi çeker.\"\"\"\n    try:\n        url = (\n            f\"https://query2.finance.yahoo.com/v8/finance/chart/\"\n            f\"{ticker}.IS?interval={interval}\u0026range={range_}\"\n        )\n        headers = {\n            \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64)\",\n            \"Accept\": \"application/json,text/html,*/*\",\n            \"Accept-Language\": \"tr-TR,tr;q=0.9\",\n            \"Referer\": \"https://finance.yahoo.com/\",\n        }\n        resp = requests.get(url, headers=headers, timeout=20)\n        if resp.status_code != 200:\n            return pd.DataFrame()\n\n        data = resp.json()\n        result = data.get(\"chart\", {}).get(\"result\", [])\n        if not result:\n            return pd.DataFrame()\n\n        r = result[0]\n        timestamps = r.get(\"timestamp\", [])\n        ohlcv = r.get(\"indicators\", {}).get(\"quote\", [{}])[0]\n\n        if not timestamps:\n            return pd.DataFrame()\n\n        df = pd.DataFrame({\n            \"datetime\": pd.to_datetime(timestamps, unit=\"s\"),\n            \"Open\":   ohlcv.get(\"open\",   []),\n            \"High\":   ohlcv.get(\"high\",   []),\n            \"Low\":    ohlcv.get(\"low\",    []),\n            \"Close\":  ohlcv.get(\"close\",  []),\n            \"Volume\": ohlcv.get(\"volume\", []),\n        })\n        df = df.set_index(\"datetime\").sort_index()\n        df.index = df.index.tz_localize(None)\n\n        for col in [\"Open\", \"High\", \"Low\", \"Close\", \"Volume\"]:\n            df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n\n        return df.dropna(subset=[\"Close\"])\n\n    except Exception as e:\n        logger.debug(f\"Yahoo hata {ticker}: {e}\")\n        return pd.DataFrame()\n\n\ndef resample_weekly(df_daily: pd.DataFrame) -\u003e pd.DataFrame:\n    \"\"\"Günlük veriyi haftalığa dönüştürür.\"\"\"\n    if df_daily.empty:\n        return pd.DataFrame()\n    df = df_daily.resample(\"W\").agg({\n        \"Open\": \"first\", \"High\": \"max\",\n        \"Low\": \"min\", \"Close\": \"last\", \"Volume\": \"sum\"\n    }).dropna(subset=[\"Close\"])\n    df.index.name = \"datetime\"\n    return df\n\n\ndef get_data(ticker: str) -\u003e tuple[pd.DataFrame, pd.DataFrame]:\n    \"\"\"\n    Bir hisse için günlük ve haftalık veri döndürür.\n    Önce PostgreSQL cache'i kontrol eder, yoksa Yahoo'dan çeker.\n    \n    Returns:\n        (df_daily, df_weekly)\n    \"\"\"\n    from core.modules.database import db\n    \n    df_daily = pd.DataFrame()\n    df_weekly = pd.DataFrame()\n\n    # Cache'den dene\n    try:\n        cached_d = _load_from_cache(f\"d:{ticker}\")\n        if cached_d is not None and not cached_d.empty:\n            df_daily = cached_d\n\n        cached_w = _load_from_cache(f\"w:{ticker}\")\n        if cached_w is not None and not cached_w.empty:\n            df_weekly = cached_w\n    except Exception:\n        pass\n\n    # Yahoo'dan çek\n    if df_daily.empty:\n        r = fetch_yahoo_direct(ticker, interval=\"1d\", range_=\"2y\")\n        if isinstance(r, pd.DataFrame) and not r.empty:\n            df_daily = r\n            _save_to_cache(f\"d:{ticker}\", r)\n\n    if df_weekly.empty:\n        r = fetch_yahoo_direct(ticker, interval=\"1wk\", range_=\"5y\")\n        if isinstance(r, pd.DataFrame) and not r.empty:\n            df_weekly = r\n            _save_to_cache(f\"w:{ticker}\", r)\n\n    if df_weekly.empty and not df_daily.empty:\n        df_weekly = resample_weekly(df_daily)\n\n    return df_daily, df_weekly\n\n\ndef _save_to_cache(key: str, df: pd.DataFrame):\n    \"\"\"DataFrame'i PostgreSQL cache'e kaydeder.\"\"\"\n    try:\n        from core.modules.database import db\n        import json\n        from sqlalchemy import text\n        \n        data = df.reset_index()\n        if \"datetime\" not in data.columns:\n            data = data.rename(columns={data.columns[0]: \"datetime\"})\n        data[\"datetime\"] = data[\"datetime\"].astype(str)\n        payload = data.to_json(orient=\"records\")\n        \n        today = datetime.now(pytz.timezone(\"Europe/Istanbul\")).date()\n        \n        with db._engine.connect() as conn:\n            conn.execute(text(\"\"\"\n                INSERT INTO price_cache(ticker, fetched_at, data) \n                VALUES(:ticker, :date, :data)\n                ON CONFLICT(ticker) DO UPDATE \n                SET fetched_at=EXCLUDED.fetched_at, data=EXCLUDED.data\n            \"\"\"), {\"ticker\": key, \"date\": today, \"data\": payload})\n            conn.commit()\n    except Exception as e:\n        logger.debug(f\"Cache kayıt hatası {key}: {e}\")\n\n\ndef _load_from_cache(key: str) -\u003e pd.DataFrame | None:\n    \"\"\"PostgreSQL cache'den DataFrame yükler.\"\"\"\n    try:\n        from core.modules.database import db\n        from sqlalchemy import text\n        \n        today = datetime.now(pytz.timezone(\"Europe/Istanbul\")).date()\n        \n        with db._engine.connect() as conn:\n            result = conn.execute(text(\n                \"SELECT data, fetched_at FROM price_cache WHERE ticker=:ticker\"\n            ), {\"ticker\": key})\n            row = result.fetchone()\n        \n        if not row:\n            return None\n        \n        fetched_at = row[1]\n        if fetched_at \u003c today:\n            return None  # Eski cache\n        \n        import json\n        records = json.loads(row[0])\n        df = pd.DataFrame(records)\n        df[\"datetime\"] = pd.to_datetime(df[\"datetime\"])\n        df = df.set_index(\"datetime\").sort_index()\n        \n        for col in [\"Open\", \"High\", \"Low\", \"Close\", \"Volume\"]:\n            if col in df.columns:\n                df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n        \n        return df\n        \n    except Exception:\n        return None\n\n\n# ============================================================\n# TEMEL TEKNİK İNDİKATÖR HESAPLAMALARI\n# ============================================================\n\ndef calc_rsi(series: pd.Series, length: int = 14) -\u003e pd.Series:\n    \"\"\"RSI (Relative Strength Index) hesaplar.\"\"\"\n    delta = series.diff()\n    gain = delta.clip(lower=0)\n    loss = -delta.clip(upper=0)\n    avg_gain = gain.ewm(com=length - 1, min_periods=length).mean()\n    avg_loss = loss.ewm(com=length - 1, min_periods=length).mean()\n    rs = avg_gain / avg_loss.replace(0, np.nan)\n    return 100 - (100 / (1 + rs))\n\n\ndef calc_ema(series: pd.Series, length: int) -\u003e pd.Series:\n    \"\"\"EMA (Exponential Moving Average) hesaplar.\"\"\"\n    return series.ewm(span=length, adjust=False).mean()\n\n\ndef calc_sma(series: pd.Series, length: int) -\u003e pd.Series:\n    \"\"\"SMA (Simple Moving Average) hesaplar.\"\"\"\n    return series.rolling(window=length).mean()\n\n\ndef calc_macd(series: pd.Series, fast: int = 12,\n              slow: int = 26, signal: int = 9) -\u003e tuple:\n    \"\"\"MACD line ve signal line döndürür.\"\"\"\n    ema_fast = series.ewm(span=fast, adjust=False).mean()\n    ema_slow = series.ewm(span=slow, adjust=False).mean()\n    macd_line = ema_fast - ema_slow\n    signal_line = macd_line.ewm(span=signal, adjust=False).mean()\n    return macd_line, signal_line\n\n\ndef calc_adx(df: pd.DataFrame, period: int = 14) -\u003e pd.Series:\n    \"\"\"ADX (Average Directional Index) hesaplar.\"\"\"\n    high = df[\"High\"]\n    low = df[\"Low\"]\n    close = df[\"Close\"]\n\n    tr1 = high - low\n    tr2 = (high - close.shift()).abs()\n    tr3 = (low - close.shift()).abs()\n    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)\n    atr = tr.rolling(period).mean()\n\n    up = high - high.shift()\n    down = low.shift() - low\n\n    plus_dm = up.where((up \u003e down) \u0026 (up \u003e 0), 0.0)\n    minus_dm = down.where((down \u003e up) \u0026 (down \u003e 0), 0.0)\n\n    plus_di = 100 * plus_dm.rolling(period).mean() / atr.replace(0, np.nan)\n    minus_di = 100 * minus_dm.rolling(period).mean() / atr.replace(0, np.nan)\n\n    dx = 100 * (plus_di - minus_di).abs() / (plus_di + minus_di).replace(0, np.nan)\n    return dx.rolling(period).mean()\n\n\ndef calc_atr(df: pd.DataFrame, period: int = 14) -\u003e pd.Series:\n    \"\"\"ATR (Average True Range) hesaplar.\"\"\"\n    high = df[\"High\"]\n    low = df[\"Low\"]\n    close = df[\"Close\"]\n\n    tr1 = high - low\n    tr2 = (high - close.shift()).abs()\n    tr3 = (low - close.shift()).abs()\n    tr = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)\n    return tr.rolling(period).mean()\n\n\ndef calc_bollinger_width(series: pd.Series, period: int = 20,\n                         std_mult: float = 2) -\u003e pd.Series:\n    \"\"\"Bollinger Band genişliğini yüzde olarak hesaplar.\"\"\"\n    sma = series.rolling(period).mean()\n    std = series.rolling(period).std()\n    upper = sma + std_mult * std\n    lower = sma - std_mult * std\n    return (upper - lower) / sma.replace(0, np.nan) * 100\n\n\ndef perf_pct(series: pd.Series, days: int) -\u003e float | None:\n    \"\"\"N günlük performans yüzdesini hesaplar.\"\"\"\n    if len(series) \u003c days + 1:\n        return None\n    base = series.iloc[-(days + 1)]\n    if base == 0 or pd.isna(base):\n        return None\n    result = (series.iloc[-1] - base) / base * 100\n    return None if pd.isna(result) else float(result)\n\n\n# ============================================================\n# PİYASA REJİMİ TESPİTİ\n# ============================================================\n\ndef detect_market_regime(df: pd.DataFrame,\n                         period: int = 50) -\u003e tuple[str, dict]:\n    \"\"\"\n    BIST piyasa rejimini tespit eder.\n    \n    Returns:\n        (regime, details)\n        regime: \"TREND_UP\" | \"TREND_DOWN\" | \"RANGE\" | \"HIGH_VOL\" | \"UNKNOWN\"\n    \"\"\"\n    try:\n        if df is None or df.empty or len(df) \u003c period + 10:\n            return \"UNKNOWN\", {}\n\n        close = df[\"Close\"]\n        sma50 = calc_sma(close, period)\n\n        if sma50.isna().iloc[-1]:\n            return \"UNKNOWN\", {}\n\n        sma_slope = (\n            (float(sma50.iloc[-1]) - float(sma50.iloc[-10]))\n            / float(sma50.iloc[-10]) * 100\n        )\n\n        adx_s = calc_adx(df)\n        adx_val = float(adx_s.iloc[-1]) if not adx_s.isna().iloc[-1] else 15\n\n        returns = close.pct_change().dropna()\n        vol_20 = float(returns.iloc[-20:].std() * 100) if len(returns) \u003e= 20 else 1.0\n        vol_60 = float(returns.iloc[-60:].std() * 100) if len(returns) \u003e= 60 else vol_20\n        vol_ratio = vol_20 / vol_60 if vol_60 \u003e 0 else 1.0\n\n        price = float(close.iloc[-1])\n        sma_val = float(sma50.iloc[-1])\n        above_sma = price \u003e sma_val\n\n        details = {\n            \"sma_slope\": round(sma_slope, 2),\n            \"adx\": round(adx_val, 1),\n            \"vol_20\": round(vol_20, 2),\n            \"vol_ratio\": round(vol_ratio, 2),\n            \"above_sma\": above_sma,\n        }\n\n        if vol_ratio \u003e 1.5 and vol_20 \u003e 2.5:\n            regime = \"HIGH_VOL\"\n        elif adx_val \u003e 25 and sma_slope \u003e 1.0 and above_sma:\n            regime = \"TREND_UP\"\n        elif adx_val \u003e 25 and sma_slope \u003c -1.0 and not above_sma:\n            regime = \"TREND_DOWN\"\n        else:\n            regime = \"RANGE\"\n\n        return regime, details\n\n    except Exception as e:\n        logger.debug(f\"Rejim tespit hatası: {e}\")\n        return \"UNKNOWN\", {}\n\n\ndef regime_strategy_weight(regime: str) -\u003e dict:\n    \"\"\"Piyasa rejimine göre strateji ağırlıkları döndürür.\"\"\"\n    weights = {\n        \"TREND_UP\":   {\"momentum\": 1.3, \"breakout\": 1.2, \"mean_rev\": 0.6, \"squeeze\": 0.8},\n        \"TREND_DOWN\": {\"momentum\": 0.5, \"breakout\": 0.7, \"mean_rev\": 1.2, \"squeeze\": 0.9},\n        \"RANGE\":      {\"momentum\": 0.7, \"breakout\": 0.8, \"mean_rev\": 1.3, \"squeeze\": 1.4},\n        \"HIGH_VOL\":   {\"momentum\": 1.1, \"breakout\": 1.0, \"mean_rev\": 0.5, \"squeeze\": 0.6},\n        \"UNKNOWN\":    {\"momentum\": 1.0, \"breakout\": 1.0, \"mean_rev\": 1.0, \"squeeze\": 1.0},\n    }\n    return weights.get(regime, weights[\"UNKNOWN\"])\n\n\n# ============================================================\n# DİVERJANS TESPİTİ\n# ============================================================\n\ndef _find_peaks(arr: np.ndarray, distance: int = 1) -\u003e tuple:\n    \"\"\"Dizideki tepe noktalarını bulur.\"\"\"\n    arr = np.asarray(arr)\n    peaks = []\n    n = len(arr)\n    i = 1\n    while i \u003c n - 1:\n        if arr[i] \u003e arr[i - 1] and arr[i] \u003e arr[i + 1]:\n            if not peaks or (i - peaks[-1]) \u003e= distance:\n                peaks.append(i)\n        i += 1\n    return np.array(peaks), {}\n\n\ndef detect_divergence(df: pd.DataFrame, window: int = 60,\n                      min_bars: int = 5,\n                      max_bars: int = 40) -\u003e tuple[str | None, str | None]:\n    \"\"\"\n    RSI diverjansı tespit eder.\n    \n    Returns:\n        (\"Bullish Diverjans\" | \"Bearish Diverjans\" | None, mesaj | None)\n    \"\"\"\n    try:\n        if \"RSI\" not in df.columns:\n            df = df.copy()\n            df[\"RSI\"] = calc_rsi(df[\"Close\"], 14)\n\n        df = df.dropna(subset=[\"Close\", \"RSI\"]).tail(window)\n        if len(df) \u003c min_bars + 5:\n            return None, None\n\n        closes = df[\"Close\"].values\n        rsis = df[\"RSI\"].values\n        last_idx = len(closes) - 1\n\n        price_lows, _ = _find_peaks(-closes, distance=min_bars)\n        rsi_lows, _   = _find_peaks(-rsis,   distance=min_bars)\n        price_highs, _ = _find_peaks(closes, distance=min_bars)\n        rsi_highs, _   = _find_peaks(rsis,  distance=min_bars)\n\n        recent_price_lows = price_lows[price_lows \u003e= last_idx - max_bars]\n        recent_rsi_lows   = rsi_lows[rsi_lows \u003e= last_idx - max_bars]\n\n        if len(recent_price_lows) \u003e= 2 and len(recent_rsi_lows) \u003e= 2:\n            p1, p2 = recent_price_lows[-2], recent_price_lows[-1]\n            r1, r2 = recent_rsi_lows[-2],   recent_rsi_lows[-1]\n            if closes[p2] \u003c closes[p1] and rsis[r2] \u003e rsis[r1]:\n                strength = \"GÜÇLÜ 🔥\" if rsis[r2] \u003c 40 else \"ORTA\"\n                return (\"Bullish Diverjans\",\n                        f\"📈 POZİTİF UYUMSUZLUK [{strength}]\\n\"\n                        f\"  Fiyat dip: {closes[p1]:.2f} → {closes[p2]:.2f} ↘\\n\"\n                        f\"  RSI  dip: {rsis[r1]:.1f} → {rsis[r2]:.1f} ↗\\n\"\n                        f\"  ⚡ Yukarı dönüş sinyali!\")\n\n        recent_price_highs = price_highs[price_highs \u003e= last_idx - max_bars]\n        recent_rsi_highs   = rsi_highs[rsi_highs \u003e= last_idx - max_bars]\n\n        if len(recent_price_highs) \u003e= 2 and len(recent_rsi_highs) \u003e= 2:\n            p1, p2 = recent_price_highs[-2], recent_price_highs[-1]\n            r1, r2 = recent_rsi_highs[-2],   recent_rsi_highs[-1]\n            if closes[p2] \u003e closes[p1] and rsis[r2] \u003c rsis[r1]:\n                strength = \"GÜÇLÜ 🔥\" if rsis[r2] \u003e 60 else \"ORTA\"\n                return (\"Bearish Diverjans\",\n                        f\"📉 NEGATİF UYUMSUZLUK [{strength}]\\n\"\n                        f\"  Fiyat tepe: {closes[p1]:.2f} → {closes[p2]:.2f} ↗\\n\"\n                        f\"  RSI  tepe: {rsis[r1]:.1f} → {rsis[r2]:.1f} ↘\\n\"\n                        f\"  ⚡ Aşağı dönüş sinyali!\")\n\n        return None, None\n\n    except Exception as e:\n        logger.debug(f\"Diverjans hatası: {e}\")\n        return None, None\n\n\n# ============================================================\n# RİSK YÖNETİMİ\n# ============================================================\n\ndef calc_risk_management(df: pd.DataFrame,\n                         signal_type: str = \"AL\") -\u003e dict | None:\n    \"\"\"\n    ATR bazlı stop-loss, hedef fiyat ve risk/reward hesaplar.\n    \n    Args:\n        signal_type: \"AL\" veya \"SAT\"\n    \n    Returns:\n        {price, atr, stop_loss, stop_pct, hedef_1/2/3, rr_1/2, destek, direnc}\n    \"\"\"\n    try:\n        if df is None or df.empty or len(df) \u003c 20:\n            return None\n\n        close = df[\"Close\"]\n        high = df[\"High\"]\n        low = df[\"Low\"]\n        price = float(close.iloc[-1])\n\n        atr_s = calc_atr(df, 14)\n        atr = float(atr_s.iloc[-1]) if not atr_s.isna().iloc[-1] else price * 0.02\n\n        recent_high = float(high.iloc[-20:].max())\n        recent_low  = float(low.iloc[-20:].min())\n        near_high   = float(high.iloc[-5:].max())\n        near_low    = float(low.iloc[-5:].min())\n\n        if signal_type == \"AL\":\n            atr_stop     = price - (atr * 1.5)\n            support_stop = near_low - (atr * 0.3)\n            stop_loss    = round(max(atr_stop, support_stop), 2)\n            hedef_1      = round(price + (atr * 2.0), 2)\n            hedef_2      = round(price + (atr * 3.5), 2)\n            hedef_3      = round(price + (atr * 5.0), 2)\n            if recent_high \u003e price and recent_high \u003c hedef_1:\n                hedef_1 = round(recent_high, 2)\n            risk     = price - stop_loss\n            rr_1     = round((hedef_1 - price) / risk, 1) if risk \u003e 0 else 0\n            rr_2     = round((hedef_2 - price) / risk, 1) if risk \u003e 0 else 0\n        else:  # SAT\n            atr_stop     = price + (atr * 1.5)\n            resist_stop  = near_high + (atr * 0.3)\n            stop_loss    = round(min(atr_stop, resist_stop), 2)\n            hedef_1      = round(price - (atr * 2.0), 2)\n            hedef_2      = round(price - (atr * 3.5), 2)\n            hedef_3      = round(price - (atr * 5.0), 2)\n            if recent_low \u003c price and recent_low \u003e hedef_1:\n                hedef_1 = round(recent_low, 2)\n            risk     = stop_loss - price\n            rr_1     = round((price - hedef_1) / risk, 1) if risk \u003e 0 else 0\n            rr_2     = round((price - hedef_2) / risk, 1) if risk \u003e 0 else 0\n\n        stop_pct = round(abs(price - stop_loss) / price * 100, 1)\n\n        return {\n            \"price\":     price,\n            \"atr\":       round(atr, 2),\n            \"stop_loss\": stop_loss,\n            \"stop_pct\":  stop_pct,\n            \"hedef_1\":   hedef_1,\n            \"hedef_2\":   hedef_2,\n            \"hedef_3\":   hedef_3,\n            \"rr_1\":      rr_1,\n            \"rr_2\":      rr_2,\n            \"destek\":    round(recent_low, 2),\n            \"direnc\":    round(recent_high, 2),\n        }\n\n    except Exception:\n        return None\n\n\ndef format_risk_text(rm: dict, signal_type: str = \"AL\") -\u003e str:\n    \"\"\"Risk yönetimi sonucunu Telegram formatında döndürür.\"\"\"\n    if not rm:\n        return \"\"\n    emoji = \"🟢\" if signal_type == \"AL\" else \"🔴\"\n    return \"\\n\".join([\n        \"🎯 *TRADE PLANI*\",\n        f\"├ {emoji} Giriş: {rm['price']:.2f}₺\",\n        f\"├ 🛑 Stop: {rm['stop_loss']:.2f}₺ (-%{rm['stop_pct']})\",\n        f\"├ 🎯 Hedef 1: {rm['hedef_1']:.2f}₺ (R/R: {rm['rr_1']})\",\n        f\"├ 🎯 Hedef 2: {rm['hedef_2']:.2f}₺ (R/R: {rm['rr_2']})\",\n        f\"├ 📏 ATR(14): {rm['atr']:.2f}₺\",\n        f\"└ 📐 Destek: {rm['destek']:.2f}₺ | Direnç: {rm['direnc']:.2f}₺\",\n    ])\n\n\n# ============================================================\n# GAP ANALİZİ\n# ============================================================\n\ndef calc_gap_analysis(df: pd.DataFrame) -\u003e dict | None:\n    \"\"\"Açılış vs önceki kapanış gap analizi yapar.\"\"\"\n    try:\n        if df is None or df.empty or len(df) \u003c 2:\n            return None\n\n        today_open  = float(df[\"Open\"].iloc[-1])\n        prev_close  = float(df[\"Close\"].iloc[-2])\n        today_close = float(df[\"Close\"].iloc[-1])\n        today_high  = float(df[\"High\"].iloc[-1])\n        today_low   = float(df[\"Low\"].iloc[-1])\n\n        if prev_close == 0 or pd.isna(prev_close):\n            return None\n\n        gap_pct      = (today_open - prev_close) / prev_close * 100\n        day_change   = (today_close - prev_close) / prev_close * 100\n\n        if gap_pct \u003e 1.5:   gap_type = \"GAP UP ⬆️\"\n        elif gap_pct \u003e 0.5:  gap_type = \"GAP UP 🟢\"\n        elif gap_pct \u003c -1.5: gap_type = \"GAP DOWN 🔴⬇\"\n        elif gap_pct \u003c -0.5: gap_type = \"GAP DOWN 🔴\"\n        else:                 gap_type = \"FLAT ➡️\"\n\n        gap_filled = (\n            (gap_pct \u003e 0.5 and today_low \u003c= prev_close) or\n            (gap_pct \u003c -0.5 and today_high \u003e= prev_close)\n        )\n\n        return {\n            \"prev_close\":    round(prev_close, 2),\n            \"today_open\":    round(today_open, 2),\n            \"today_close\":   round(today_close, 2),\n            \"gap_pct\":       round(gap_pct, 2),\n            \"gap_type\":      gap_type,\n            \"gap_filled\":    gap_filled,\n            \"day_change_pct\": round(day_change, 2),\n        }\n\n    except Exception:\n        return None\n\n\n# ============================================================\n# HACİM \u0026 MOMENTUM ANALİZİ\n# ============================================================\n\ndef calc_volume_momentum(df: pd.DataFrame, vol_period: int = 20) -\u003e dict:\n    \"\"\"Hacim ve momentum analizi yapar.\"\"\"\n    result = {\n        \"vol_ratio\": None, \"vol_trend\": \"NOTR\",\n        \"buy_pressure\": None, \"mom_fast\": None,\n        \"obv_trend\": \"NOTR\", \"confirm_buy\": False,\n        \"summary\": \"❓ Hacim verisi yok\"\n    }\n\n    try:\n        if \"Volume\" not in df.columns or len(df) \u003c vol_period + 2:\n            return result\n\n        close  = df[\"Close\"]\n        volume = df[\"Volume\"].replace(0, np.nan)\n\n        avg_vol  = volume.iloc[-(vol_period + 1):-1].mean()\n        last_vol = volume.iloc[-1]\n        vol_ratio = last_vol / avg_vol if (avg_vol and avg_vol \u003e 0) else None\n        result[\"vol_ratio\"] = vol_ratio\n\n        # Hacim trendi\n        recent_vol = volume.dropna().iloc[-5:]\n        if len(recent_vol) \u003e= 3:\n            x = np.arange(len(recent_vol))\n            slope = np.polyfit(x, recent_vol.values, 1)[0]\n            norm = recent_vol.mean()\n            if norm \u003e 0:\n                slope_pct = slope / norm * 100\n                if slope_pct \u003e 5:\n                    result[\"vol_trend\"] = \"YUKARI\"\n                elif slope_pct \u003c -5:\n                    result[\"vol_trend\"] = \"ASAGI\"\n\n        # Alım baskısı\n        last10 = df.iloc[-10:].copy()\n        last10[\"up\"] = last10[\"Close\"] \u003e last10[\"Close\"].shift(1)\n        up_vol    = last10.loc[last10[\"up\"], \"Volume\"].sum()\n        total_vol = last10[\"Volume\"].sum()\n        if total_vol \u003e 0:\n            result[\"buy_pressure\"] = up_vol / total_vol\n\n        # Momentum\n        if len(close) \u003e 5:\n            result[\"mom_fast\"] = round(\n                (float(close.iloc[-1]) / float(close.iloc[-5]) - 1) * 100, 2\n            )\n\n        # OBV\n        obv = (np.sign(close.diff()) * volume).fillna(0).cumsum()\n        obv_recent = obv.iloc[-10:]\n        if len(obv_recent) \u003e= 5:\n            x = np.arange(len(obv_recent))\n            obv_slope = np.polyfit(x, obv_recent.values, 1)[0]\n            obv_mean  = abs(obv_recent.mean())\n            if obv_mean \u003e 0:\n                obv_pct = obv_slope / obv_mean * 100\n                if obv_pct \u003e 2:\n                    result[\"obv_trend\"] = \"YUKARI\"\n                elif obv_pct \u003c -2:\n                    result[\"obv_trend\"] = \"ASAGI\"\n\n        # Onay\n        vr = vol_ratio or 0\n        bp = result[\"buy_pressure\"] or 0.5\n        mf = result[\"mom_fast\"] or 0\n        buy_score = (\n            (1 if vr \u003e= 1.2 else 0) +\n            (1 if bp \u003e= 0.55 else 0) +\n            (1 if mf \u003e 0 else 0) +\n            (1 if result[\"obv_trend\"] == \"YUKARI\" else 0)\n        )\n        result[\"confirm_buy\"] = buy_score \u003e= 3\n\n    except Exception as e:\n        result[\"summary\"] = f\"❓ Hata: {e}\"\n\n    return result\n\n\n# ============================================================\n# MULTI-TIMEFRAME SKOR ENGİNE\n# ============================================================\n\ndef calc_mtf_score(df_d: pd.DataFrame, df_w: pd.DataFrame,\n                   ticker: str) -\u003e tuple[int, dict]:\n    \"\"\"\n    Günlük + haftalık + hacim + momentum birleşik skor.\n    \n    Returns:\n        (score 0-100, detaylar)\n    \"\"\"\n    try:\n        total = 0\n        max_total = 0\n        scores = {}\n\n        # Günlük trend (max 25)\n        if df_d is not None and not df_d.empty and len(df_d) \u003e= 50:\n            d_close = df_d[\"Close\"]\n            d_sma20 = calc_sma(d_close, 20)\n            d_sma50 = calc_sma(d_close, 50)\n            d_rsi   = calc_rsi(d_close, 14)\n            price   = float(d_close.iloc[-1])\n\n            d_score = 0\n            if not d_sma20.isna().iloc[-1] and price \u003e float(d_sma20.iloc[-1]):\n                d_score += 5\n            if not d_sma50.isna().iloc[-1] and price \u003e float(d_sma50.iloc[-1]):\n                d_score += 5\n            if (not d_sma20.isna().iloc[-1] and not d_sma50.isna().iloc[-1]\n                    and float(d_sma20.iloc[-1]) \u003e float(d_sma50.iloc[-1])):\n                d_score += 5\n\n            rsi_val = float(d_rsi.iloc[-1]) if not d_rsi.isna().iloc[-1] else 50\n            if 40 \u003c= rsi_val \u003c= 70:\n                d_score += 5\n            elif 30 \u003c= rsi_val \u003c 40:\n                d_score += 3\n\n            macd_l, macd_s = calc_macd(d_close)\n            if (not macd_l.isna().iloc[-1] and\n                    float(macd_l.iloc[-1]) \u003e float(macd_s.iloc[-1])):\n                d_score += 5\n\n            scores[\"daily_trend\"] = d_score\n            total     += d_score\n            max_total += 25\n\n        # Haftalık trend (max 25)\n        if df_w is not None and not df_w.empty and len(df_w) \u003e= 20:\n            w_close = df_w[\"Close\"]\n            w_sma20 = calc_sma(w_close, 20)\n            w_rsi   = calc_rsi(w_close, 14)\n            w_price = float(w_close.iloc[-1])\n\n            w_score = 0\n            if not w_sma20.isna().iloc[-1] and w_price \u003e float(w_sma20.iloc[-1]):\n                w_score += 8\n\n            w_rsi_val = float(w_rsi.iloc[-1]) if not w_rsi.isna().iloc[-1] else 50\n            if 40 \u003c= w_rsi_val \u003c= 70:\n                w_score += 7\n            elif 30 \u003c= w_rsi_val \u003c 40:\n                w_score += 4\n\n            w_macd_l, w_macd_s = calc_macd(w_close)\n            if (not w_macd_l.isna().iloc[-1] and\n                    float(w_macd_l.iloc[-1]) \u003e float(w_macd_s.iloc[-1])):\n                w_score += 10\n\n            scores[\"weekly_trend\"] = w_score\n            total     += w_score\n            max_total += 25\n\n        # Hacim skoru (max 25)\n        if df_d is not None and not df_d.empty and len(df_d) \u003e= 25:\n            vm = calc_volume_momentum(df_d)\n            v_score = 0\n\n            vr = vm.get(\"vol_ratio\") or 0\n            if vr \u003e= 2.0:   v_score += 10\n            elif vr \u003e= 1.5: v_score += 7\n            elif vr \u003e= 1.0: v_score += 4\n\n            if vm.get(\"obv_trend\") == \"YUKARI\": v_score += 8\n            elif vm.get(\"obv_trend\") == \"NOTR\":  v_score += 3\n\n            bp = vm.get(\"buy_pressure\") or 0.5\n            if bp \u003e= 0.60:   v_score += 7\n            elif bp \u003e= 0.50: v_score += 4\n\n            scores[\"volume\"] = v_score\n            total     += v_score\n            max_total += 25\n\n        # Momentum skoru (max 25)\n        if df_d is not None and not df_d.empty and len(df_d) \u003e= 25:\n            d_close = df_d[\"Close\"]\n            m_score = 0\n\n            perf_5  = perf_pct(d_close, 5)\n            perf_21 = perf_pct(d_close, 21)\n            adx_s   = calc_adx(df_d)\n            adx_val = float(adx_s.iloc[-1]) if not adx_s.isna().iloc[-1] else 15\n\n            if perf_5 is not None and perf_5 \u003e 3:  m_score += 6\n            elif perf_5 is not None and perf_5 \u003e 0: m_score += 3\n\n            if perf_21 is not None and perf_21 \u003e 8:  m_score += 6\n            elif perf_21 is not None and perf_21 \u003e 0: m_score += 3\n\n            if adx_val \u003e 30:   m_score += 7\n            elif adx_val \u003e 20: m_score += 4\n\n            if len(d_close) \u003e 10:\n                roc = (float(d_close.iloc[-1]) / float(d_close.iloc[-10]) - 1) * 100\n                if roc \u003e 5:  m_score += 6\n                elif roc \u003e 0: m_score += 3\n\n            scores[\"momentum\"] = m_score\n            total     += m_score\n            max_total += 25\n\n        final_score = int(total / max_total * 100) if max_total \u003e 0 else 0\n        scores[\"total\"] = final_score\n        return final_score, scores\n\n    except Exception:\n        return 0, {}\n\n\ndef score_to_label(score: int) -\u003e str:\n    \"\"\"MTF skorunu etiketle.\"\"\"\n    if score \u003e= 80:   return \"GÜÇLÜ AL++ 🟢🟢\"\n    elif score \u003e= 65: return \"AL+ 🟢\"\n    elif score \u003e= 50: return \"ORTA AL 🟡\"\n    elif score \u003e= 35: return \"ZAYIF / BEKLE ⚪\"\n    elif score \u003e= 20: return \"ZAYIF SAT 🔴\"\n    else:             return \"GÜÇLÜ SAT 🔴🔴\"\n\n\n# ============================================================\n# ANA İNDİKATÖR HESAPLAYICI (Tüm stratejiler için)\n# ============================================================\n\ndef tara_indicators(ticker: str,\n                    df_d: pd.DataFrame | None = None) -\u003e dict | None:\n    \"\"\"\n    Bir hisse için tüm teknik indikatörleri hesaplar.\n    df_d verilmişse get_data() çağırmaz (performans optimizasyonu).\n    \n    Returns:\n        dict with 50+ indicators or None if insufficient data\n    \"\"\"\n    if df_d is None:\n        df_d, _ = get_data(ticker)\n\n    if not isinstance(df_d, pd.DataFrame) or df_d.empty or len(df_d) \u003c 60:\n        return None\n\n    try:\n        d = df_d.copy()\n        close  = d[\"Close\"]\n        high   = d[\"High\"]\n        low    = d[\"Low\"]\n        volume = d[\"Volume\"]\n        open_  = d[\"Open\"] if \"Open\" in d.columns else close\n        price  = float(close.iloc[-1])\n\n        # Kapanış yönü\n        kapanis_yukari = (\n            not pd.isna(close.iloc[-1]) and\n            not pd.isna(open_.iloc[-1]) and\n            float(close.iloc[-1]) \u003e float(open_.iloc[-1])\n        )\n\n        # ── SMA / EMA ──\n        sma20  = calc_sma(close, 20)\n        sma50  = calc_sma(close, 50)\n        sma200 = calc_sma(close, 200)\n        s20  = float(sma20.iloc[-1])  if not sma20.isna().iloc[-1]  else None\n        s50  = float(sma50.iloc[-1])  if not sma50.isna().iloc[-1]  else None\n        s200 = float(sma200.iloc[-1]) if not sma200.isna().iloc[-1] else None\n\n        ema9_s  = calc_ema(close, 9)\n        ema21_s = calc_ema(close, 21)\n        e9  = float(ema9_s.iloc[-1])  if not ema9_s.isna().iloc[-1]  else None\n        e21 = float(ema21_s.iloc[-1]) if not ema21_s.isna().iloc[-1] else None\n        ema_dizilimi = (\n            e9 is not None and e21 is not None and s50 is not None\n            and e9 \u003e e21 \u003e s50\n        )\n        near_sma50 = (\n            s50 is not None and s50 \u003e 0\n            and abs(price - s50) / s50 * 100 \u003c= 5\n        )\n\n        # ── RSI ──\n        rsi_s    = calc_rsi(close, 14).dropna()\n        rsi      = float(rsi_s.iloc[-1]) if len(rsi_s) \u003e= 1 else None\n        rsi_prev = float(rsi_s.iloc[-2]) if len(rsi_s) \u003e= 2 else None\n        rsi_prev2 = float(rsi_s.iloc[-3]) if len(rsi_s) \u003e= 3 else None\n        rsi_yukari_3g = (\n            rsi is not None and rsi_prev is not None and rsi_prev2 is not None\n            and rsi \u003e rsi_prev \u003e rsi_prev2\n        )\n        rsi_30_cross_up = (\n            rsi_prev is not None and rsi is not None\n            and rsi_prev \u003c= 30 and rsi \u003e 30\n        )\n        rsi_50_cross_up = (\n            rsi_prev is not None and rsi is not None\n            and rsi_prev \u003c= 50 and rsi \u003e 50\n        )\n\n        # ── MACD ──\n        macd_line, macd_sig_line = calc_macd(close)\n        macd_val     = float(macd_line.iloc[-1])     if not macd_line.isna().iloc[-1]     else None\n        macd_sig_val = float(macd_sig_line.iloc[-1]) if not macd_sig_line.isna().iloc[-1] else None\n        macd_prev     = float(macd_line.iloc[-2])     if (len(macd_line) \u003e= 2     and not pd.isna(macd_line.iloc[-2]))     else None\n        macd_sig_prev = float(macd_sig_line.iloc[-2]) if (len(macd_sig_line) \u003e= 2 and not pd.isna(macd_sig_line.iloc[-2])) else None\n\n        if macd_val is not None and macd_sig_val is not None:\n            hist_cur = macd_val - macd_sig_val\n            hist_prev = (\n                (macd_prev - macd_sig_prev)\n                if (macd_prev is not None and macd_sig_prev is not None)\n                else None\n            )\n            macd_hist_pozitif       = hist_cur \u003e 0\n            macd_hist_artiyor       = hist_prev is not None and hist_cur \u003e hist_prev\n            macd_hist_pozitif_kesim = hist_prev is not None and hist_prev \u003c= 0 and hist_cur \u003e 0\n        else:\n            macd_hist_pozitif = macd_hist_artiyor = macd_hist_pozitif_kesim = False\n\n        macd_above_signal = (\n            macd_val is not None and macd_sig_val is not None\n            and macd_val \u003e macd_sig_val\n        )\n        macd_fresh_cross = (\n            macd_val is not None and macd_sig_val is not None\n            and macd_prev is not None and macd_sig_prev is not None\n            and macd_val \u003e macd_sig_val and macd_prev \u003c= macd_sig_prev\n        )\n\n        # ── ADX / ATR ──\n        adx_s = calc_adx(d)\n        adx   = float(adx_s.iloc[-1]) if not adx_s.isna().iloc[-1] else None\n        atr_s = calc_atr(d, 14)\n        atr   = float(atr_s.iloc[-1]) if not atr_s.isna().iloc[-1] else None\n        atr_pct = (atr / price * 100) if (atr and price \u003e 0) else None\n\n        # ── Bollinger ──\n        bb_width_s = calc_bollinger_width(close)\n        bb_width   = float(bb_width_s.iloc[-1]) if not bb_width_s.isna().iloc[-1] else None\n        bb_avg20_raw = bb_width_s.rolling(20).mean().iloc[-1]\n        bb_avg20 = float(bb_avg20_raw) if (len(bb_width_s) \u003e 20 and not pd.isna(bb_avg20_raw)) else None\n        bb_avg60_raw = bb_width_s.rolling(60).mean().iloc[-1]\n        bb_avg60 = float(bb_avg60_raw) if (len(bb_width_s) \u003e 60 and not pd.isna(bb_avg60_raw)) else bb_avg20\n\n        bb_width_low   = bb_width is not None and bb_avg20 is not None and bb_width \u003c bb_avg20\n        bb_width_low60 = (bb_width is not None and bb_avg60 is not None\n                          and bb_avg60 \u003e 0 and bb_width \u003c bb_avg60 * 0.70)\n        bb_width_low65 = (bb_width is not None and bb_avg60 is not None\n                          and bb_avg60 \u003e 0 and bb_width \u003c bb_avg60 * 0.65)\n\n        # ── VWAP ──\n        typical_price = (high + low + close) / 3\n        vwap_s   = (typical_price * volume).rolling(20).sum() / volume.rolling(20).sum().replace(0, float(\"nan\"))\n        vwap_raw = vwap_s.iloc[-1]\n        vwap     = float(vwap_raw) if (vwap_raw is not None and not pd.isna(vwap_raw)) else None\n        price_above_vwap = (vwap is not None and price \u003e vwap)\n\n        # ── Hacim ──\n        vol_avg20_raw = volume.rolling(20).mean().iloc[-1]\n        vol_avg20 = float(vol_avg20_raw) if not pd.isna(vol_avg20_raw) else 0.0\n        vol_cur   = float(volume.iloc[-1]) if not pd.isna(volume.iloc[-1]) else 0.0\n        rel_vol   = vol_cur / vol_avg20 if vol_avg20 \u003e 0 else 0\n        vol_above_avg = vol_cur \u003e vol_avg20\n\n        # Hacim trendi (son 3 gün)\n        vol_trend_up = False\n        if len(volume) \u003e= 4:\n            v1 = float(volume.iloc[-3]) if not pd.isna(volume.iloc[-3]) else 0\n            v2 = float(volume.iloc[-2]) if not pd.isna(volume.iloc[-2]) else 0\n            v3 = float(volume.iloc[-1]) if not pd.isna(volume.iloc[-1]) else 0\n            vol_trend_up = v3 \u003e v2 \u003e v1 \u003e 0\n\n        # OBV\n        obv     = (np.sign(close.diff()) * volume).fillna(0).cumsum()\n        obv_ema = obv.ewm(span=21, adjust=False).mean()\n        obv_bullish = float(obv.iloc[-1]) \u003e float(obv_ema.iloc[-1]) if not obv.isna().iloc[-1] else False\n\n        # Alım baskısı (son 10 bar)\n        buy_pressure = None\n        if len(d) \u003e= 10:\n            last10      = d.iloc[-10:].copy()\n            last10[\"up\"] = last10[\"Close\"] \u003e last10[\"Close\"].shift(1)\n            up_vol       = last10.loc[last10[\"up\"], \"Volume\"].sum()\n            total_vol    = last10[\"Volume\"].sum()\n            if total_vol \u003e 0:\n                buy_pressure = up_vol / total_vol\n\n        # ── Performans ──\n        perf_1d   = perf_pct(close, 1)\n        perf_5d   = perf_pct(close, 5)\n        perf_21d  = perf_pct(close, 21)\n        perf_63d  = perf_pct(close, 63)\n        perf_252d = perf_pct(close, 252)\n\n        # ── Destek/Direnç ──\n        recent_low_20  = float(low.iloc[-20:].min())  if len(low)  \u003e= 20 else None\n        recent_high_20 = float(high.iloc[-20:].max()) if len(high) \u003e= 20 else None\n        near_support   = (recent_low_20  is not None and price \u003e 0\n                          and abs(price - recent_low_20)  / price * 100 \u003c 3)\n        near_resistance = (recent_high_20 is not None and price \u003e 0\n                           and abs(price - recent_high_20) / price * 100 \u003c 3)\n\n        # ── Ardışık yeşil mumlar ──\n        green_streak = 0\n        for j in range(1, min(11, len(d))):\n            c_j = float(close.iloc[-j])\n            o_j = float(open_.iloc[-j])\n            if not pd.isna(c_j) and not pd.isna(o_j) and c_j \u003e o_j:\n                green_streak += 1\n            else:\n                break\n\n        # ── Diverjans ──\n        has_bullish_div = has_bearish_div = False\n        try:\n            d_copy = d.copy()\n            d_copy[\"RSI\"] = calc_rsi(d_copy[\"Close\"], 14)\n            dt, _ = detect_divergence(d_copy, window=60)\n            if dt == \"Bullish Diverjans\":  has_bullish_div = True\n            elif dt == \"Bearish Diverjans\": has_bearish_div = True\n        except Exception:\n            pass\n\n        return {\n            \"ticker\": ticker, \"price\": price,\n            \"kapanis_yukari\": kapanis_yukari,\n            \"sma20\": s20, \"sma50\": s50, \"sma200\": s200,\n            \"near_sma50\": near_sma50,\n            \"ema9\": e9, \"ema21\": e21, \"ema_dizilimi\": ema_dizilimi,\n            \"rsi\": rsi, \"rsi_prev\": rsi_prev, \"rsi_yukari_3g\": rsi_yukari_3g,\n            \"rsi_30_cross_up\": rsi_30_cross_up, \"rsi_50_cross_up\": rsi_50_cross_up,\n            \"macd\": macd_val, \"macd_sig\": macd_sig_val,\n            \"macd_above_signal\": macd_above_signal,\n            \"macd_fresh_cross\": macd_fresh_cross,\n            \"macd_hist_pozitif\": macd_hist_pozitif,\n            \"macd_hist_artiyor\": macd_hist_artiyor,\n            \"macd_hist_pozitif_kesim\": macd_hist_pozitif_kesim,\n            \"adx\": adx, \"atr\": atr, \"atr_pct\": atr_pct,\n            \"bb_width\": bb_width, \"bb_width_low\": bb_width_low,\n            \"bb_width_low60\": bb_width_low60, \"bb_width_low65\": bb_width_low65,\n            \"vwap\": vwap, \"price_above_vwap\": price_above_vwap,\n            \"vol_avg20\": vol_avg20, \"vol_cur\": vol_cur, \"rel_vol\": rel_vol,\n            \"vol_above_avg\": vol_above_avg, \"vol_trend_up\": vol_trend_up,\n            \"obv_bullish\": obv_bullish, \"buy_pressure\": buy_pressure,\n            \"perf_1d\": perf_1d, \"perf_5d\": perf_5d,\n            \"perf_21d\": perf_21d, \"perf_63d\": perf_63d, \"perf_252d\": perf_252d,\n            \"has_bullish_div\": has_bullish_div, \"has_bearish_div\": has_bearish_div,\n            \"near_support\": near_support, \"near_resistance\": near_resistance,\n            \"green_streak\": green_streak,\n        }\n\n    except Exception as e:\n        logger.error(f\"tara_indicators hatası {ticker}: {e}\")\n        return None\n\n\n# ============================================================\n# STRATEJİ FİLTRELERİ (bot.py'den birebir taşındı)\n# ============================================================\n\ndef strateji_filtre(ind: dict, kod: str) -\u003e bool:\n    \"\"\"\n    Verilen indikatör setini belirtilen strateji koduna göre filtreler.\n    \n    Args:\n        ind: tara_indicators() çıktısı\n        kod: strateji kodu (\"1\"-\"16\", \"A\", \"B\", \"C\")\n    \n    Returns:\n        True → eşleşti, False → eşleşmedi\n    \"\"\"\n    p = ind\n    price = p[\"price\"]\n\n    def gt(val, thr):      return val is not None and val \u003e thr\n    def lt(val, thr):      return val is not None and val \u003c thr\n    def between(v, lo, hi): return v is not None and lo \u003c= v \u003c= hi\n    def near(v, ref, pct):\n        return (v is not None and ref is not None\n                and ref \u003e 0 and abs(v - ref) / ref * 100 \u003c= pct)\n\n    if kod == \"1\":\n        return (gt(price, p[\"sma200\"] or 0) and near(price, p[\"sma50\"], 5)\n                and between(p[\"rsi\"], 40, 68)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.8)\n                and gt(p[\"rel_vol\"], 1.8) and p[\"bb_width_low60\"]\n                and between(p[\"perf_5d\"], 0, 6) and gt(p[\"perf_21d\"], 11)\n                and gt(p[\"adx\"], 25) and p[\"price_above_vwap\"]\n                and p[\"kapanis_yukari\"] and p[\"macd_hist_artiyor\"])\n\n    elif kod == \"2\":\n        return (gt(price, p[\"sma20\"] or 0) and gt(price, p[\"sma50\"] or 0)\n                and between(p[\"rsi\"], 50, 74)\n                and gt(p[\"macd\"], p[\"macd_sig\"] if p[\"macd_sig\"] is not None else -999)\n                and p[\"macd_hist_pozitif\"] and p[\"macd_hist_artiyor\"]\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.8)\n                and gt(p[\"rel_vol\"], 1.8)\n                and gt(p[\"perf_1d\"], 2) and gt(p[\"perf_5d\"], 5)\n                and lt(p[\"perf_21d\"], 11)\n                and gt(p[\"adx\"], 25) and p[\"price_above_vwap\"]\n                and p[\"rsi_yukari_3g\"])\n\n    elif kod == \"3\":\n        rsi_yukari = (p[\"rsi\"] is not None and p[\"rsi_prev\"] is not None\n                      and p[\"rsi\"] \u003e p[\"rsi_prev\"])\n        return (lt(p[\"rsi\"], 45) and rsi_yukari\n                and gt(price, p[\"sma20\"] or 0)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.8)\n                and gt(p[\"rel_vol\"], 1.8)\n                and gt(p[\"perf_1d\"], 2)\n                and lt(p[\"perf_5d\"], 0) and lt(p[\"perf_21d\"], 0)\n                and gt(p[\"adx\"], 25) and p[\"price_above_vwap\"]\n                and p[\"macd_hist_pozitif_kesim\"])\n\n    elif kod == \"4\":\n        return (gt(price, p[\"sma50\"] or 0) and gt(price, p[\"sma200\"] or 0)\n                and between(p[\"rsi\"], 56, 74)\n                and gt(p[\"macd\"], p[\"macd_sig\"] if p[\"macd_sig\"] is not None else -999)\n                and p[\"macd_hist_pozitif\"] and p[\"macd_hist_artiyor\"]\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 2.0)\n                and gt(p[\"rel_vol\"], 1.9)\n                and gt(p[\"perf_5d\"], 8) and gt(p[\"perf_21d\"], 13)\n                and gt(p[\"adx\"], 28))\n\n    elif kod == \"6\":\n        return (gt(price, p[\"sma20\"] or 0) and gt(price, p[\"sma50\"] or 0)\n                and between(p[\"rsi\"], 64, 82)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 2.2)\n                and gt(p[\"rel_vol\"], 2.2)\n                and gt(p[\"perf_1d\"], 5) and gt(p[\"perf_5d\"], 16)\n                and gt(p[\"perf_21d\"], 26) and gt(p[\"adx\"], 32)\n                and p[\"macd_hist_artiyor\"] and p[\"price_above_vwap\"])\n\n    elif kod == \"7\":\n        return (gt(price, p[\"sma50\"] or 0) and gt(price, p[\"sma200\"] or 0)\n                and between(p[\"rsi\"], 54, 70) and p[\"macd_fresh_cross\"]\n                and p[\"macd_hist_pozitif\"] and p[\"macd_hist_artiyor\"]\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.9)\n                and gt(p[\"rel_vol\"], 1.8)\n                and gt(p[\"perf_1d\"], 3) and gt(p[\"perf_5d\"], 9)\n                and between(p[\"perf_21d\"], 0, 11)\n                and gt(p[\"adx\"], 25) and p[\"price_above_vwap\"])\n\n    elif kod == \"8\":\n        return (gt(price, p[\"sma20\"] or 0) and gt(price, p[\"sma50\"] or 0)\n                and gt(p[\"sma20\"] or 0, p[\"sma50\"] or 0)\n                and between(p[\"rsi\"], 48, 66)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.8)\n                and gt(p[\"rel_vol\"], 1.8)\n                and between(p[\"perf_5d\"], 0, 7) and between(p[\"perf_21d\"], 0, 13)\n                and gt(p[\"adx\"], 25) and p[\"price_above_vwap\"])\n\n    elif kod == \"9\":\n        return (gt(price, p[\"sma50\"] or 0) and between(p[\"rsi\"], 44, 62)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.9)\n                and gt(p[\"rel_vol\"], 1.9)\n                and between(p[\"perf_5d\"], 0, 7) and between(p[\"perf_21d\"], 6, 22)\n                and gt(p[\"adx\"], 25) and p[\"price_above_vwap\"]\n                and p[\"macd_hist_pozitif\"])\n\n    elif kod == \"10\":\n        return (near(price, p[\"sma50\"], 5) and between(p[\"rsi\"], 38, 56)\n                and between(p[\"perf_1d\"], -1.5, 1.5)\n                and between(p[\"perf_5d\"], -4, 4)\n                and lt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 0.7)\n                and p[\"bb_width_low65\"] and lt(p[\"adx\"], 20))\n\n    elif kod == \"11\":\n        return (gt(price, p[\"sma20\"] or 0) and gt(p[\"rsi\"], 56)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 2.2)\n                and gt(p[\"rel_vol\"], 2.2)\n                and gt(p[\"perf_1d\"], 3) and gt(p[\"perf_5d\"], 9)\n                and gt(p[\"adx\"], 28) and p[\"price_above_vwap\"])\n\n    elif kod == \"12\":\n        return (gt(price, p[\"sma50\"] or 0) and gt(price, p[\"sma200\"] or 0)\n                and gt(p[\"rsi\"], 59)\n                and gt(p[\"perf_5d\"], 11) and gt(p[\"perf_21d\"], 19)\n                and gt(p[\"perf_63d\"], 32) and gt(p[\"adx\"], 26))\n\n    elif kod == \"13\":\n        return (lt(p[\"perf_252d\"], -28) and lt(p[\"rsi\"], 43)\n                and gt(price, p[\"sma20\"] or 0)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.8)\n                and gt(p[\"perf_1d\"], 2)\n                and gt(p[\"rel_vol\"], 1.8) and gt(p[\"adx\"], 22))\n\n    elif kod == \"14\":\n        return (gt(price, p[\"sma50\"] or 0) and gt(price, p[\"sma200\"] or 0)\n                and between(p[\"rsi\"], 61, 78) and gt(p[\"adx\"], 32)\n                and gt(p[\"macd\"], p[\"macd_sig\"] if p[\"macd_sig\"] is not None else -999)\n                and p[\"macd_hist_artiyor\"]\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 2.2)\n                and gt(p[\"perf_5d\"], 13) and gt(p[\"perf_21d\"], 21)\n                and p[\"price_above_vwap\"])\n\n    elif kod == \"15\":\n        return (gt(price, p[\"sma50\"] or 0) and gt(p[\"rsi\"], 56)\n                and between(p[\"perf_5d\"], 6, 30)\n                and gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.8)\n                and gt(p[\"adx\"], 25) and p[\"macd_hist_pozitif\"]\n                and p[\"price_above_vwap\"])\n\n    elif kod == \"16\":\n        return (gt(price, p[\"sma50\"] or 0) and gt(price, p[\"sma200\"] or 0)\n                and p.get(\"ema_dizilimi\", False)\n                and p[\"macd_hist_pozitif\"] and p[\"macd_above_signal\"]\n                and between(p[\"rsi\"], 50, 70)\n                and gt(p[\"adx\"], 18))\n\n    elif kod == \"A\":\n        return (gt(price, p[\"sma50\"] or 0) and gt(price, p[\"sma200\"] or 0)\n                and gt(p[\"perf_5d\"], 5) and gt(p[\"perf_21d\"], 10)\n                and gt(p[\"rsi\"], 50))\n\n    elif kod == \"B\":\n        return (gt(p[\"vol_cur\"], (p[\"vol_avg20\"] or 0) * 1.5)\n                and gt(p[\"rel_vol\"], 1.5)\n                and gt(p[\"perf_1d\"], 1) and gt(p[\"rsi\"], 45)\n                and gt(price, p[\"sma20\"] or 0))\n\n    elif kod == \"C\":\n        return (gt(p[\"perf_1d\"], 0) and gt(p[\"perf_5d\"], 3)\n                and gt(p[\"rsi\"], 50) and gt(price, p[\"sma50\"] or 0))\n\n    return False\n\n\n# ============================================================\n# SPADE HUNTER\n# ============================================================\n\ndef _spade_calc_cmf(high: pd.Series, low: pd.Series,\n                    close: pd.Series, volume: pd.Series,\n                    period: int = 21) -\u003e pd.Series:\n    \"\"\"Chaikin Money Flow hesaplar.\"\"\"\n    denom = (high - low).replace(0, np.nan)\n    mfm   = ((close - low) - (high - close)) / denom\n    mfv   = mfm * volume\n    return mfv.rolling(period).sum() / volume.rolling(period).sum().replace(0, np.nan)\n\n\ndef _spade_calc_obv(close: pd.Series, volume: pd.Series) -\u003e pd.Series:\n    \"\"\"On-Balance Volume hesaplar.\"\"\"\n    direction = np.sign(close.diff().fillna(0))\n    return (direction * volume).cumsum()\n\n\ndef spade_indicators(ticker: str) -\u003e dict | None:\n    \"\"\"\n    SpadeHunter composite sinyal sistemi.\n    Haftalık veri üzerinde çalışır.\n    \n    Returns:\n        dict with SpadeHunter results or None if no signal\n    \"\"\"\n    df_d, df_w = get_data(ticker)\n\n    if df_w is None or df_w.empty:\n        if df_d is not None and not df_d.empty:\n            df_w = resample_weekly(df_d)\n        else:\n            return None\n\n    if len(df_w) \u003c 60:\n        return None\n\n    try:\n        d = df_w.copy()\n\n        # Haftanın ortasındaki mevcut haftayı çıkar\n        tr_now = datetime.now(pytz.timezone(\"Europe/Istanbul\"))\n        if tr_now.weekday() \u003c 5 and len(d) \u003e 1:\n            d = d.iloc[:-1]\n\n        close  = d[\"Close\"]\n        high   = d[\"High\"]\n        low    = d[\"Low\"]\n        volume = d[\"Volume\"]\n        open_  = d[\"Open\"] if \"Open\" in d.columns else close\n        price  = float(close.iloc[-1])\n\n        # İndikatörler\n        sma20  = calc_sma(close, 20)\n        sma50  = calc_sma(close, 50)\n        sma200 = calc_sma(close, 200)\n        rsi14  = calc_rsi(close, 14)\n\n        macd_line, macd_sig = calc_macd(close)\n        macd_hist    = macd_line - macd_sig\n        macd_hist_ris = macd_hist \u003e macd_hist.shift(1)\n        macd_full_bull = (macd_line \u003e macd_sig) \u0026 (macd_hist \u003e 0) \u0026 macd_hist_ris\n        macd_hist_pos  = macd_hist \u003e 0\n\n        vma20     = volume.rolling(20).mean()\n        rvol      = volume / vma20.replace(0, np.nan)\n        vol_trend3 = (volume \u003e volume.shift(1)) \u0026 (volume.shift(1) \u003e volume.shift(2))\n        early_vol  = (rvol \u003e= SPADE_VOL_EARLY) \u0026 vol_trend3\n        high_vol   = rvol \u003e= SPADE_VOL_MULT\n\n        adx_s       = calc_adx(d)\n        strong_trend = adx_s \u003e SPADE_ADX_THRESH\n\n        # VWAP (yıllık)\n        hlc3      = (high + low + close) / 3\n        cum_tp    = (hlc3 * volume).rolling(252, min_periods=1).sum()\n        cum_v     = volume.rolling(252, min_periods=1).sum().replace(0, np.nan)\n        vwap_s    = cum_tp / cum_v\n        above_vwap = close \u003e vwap_s\n\n        # Bollinger Squeeze\n        bb_width  = calc_bollinger_width(close, 20, 2)\n        bb_wma60  = bb_width.rolling(60).mean()\n        bb_sqz    = bb_width \u003c bb_wma60 * 0.70\n        bb_tsqz   = bb_width \u003c bb_wma60 * 0.65\n\n        # CMF ve OBV\n        cmf21      = _spade_calc_cmf(high, low, close, volume, 21)\n        cmf_pos    = cmf21 \u003e 0.05\n        cmf_strong = cmf21 \u003e 0.15\n        obv_val    = _spade_calc_obv(close, volume)\n        obv_ema    = obv_val.ewm(span=21, adjust=False).mean()\n        obv_bull   = obv_val \u003e obv_ema\n\n        # Performans\n        perf_d = (close / close.shift(1)  - 1.0) * 100.0\n        perf_w = (close / close.shift(5)  - 1.0) * 100.0\n        perf_m = (close / close.shift(21) - 1.0) * 100.0\n\n        rsi_x50 = (\n            ((rsi14.shift(2) \u003c= 50) \u0026 (rsi14.shift(1) \u003e 50)) |\n            ((rsi14.shift(1) \u003c= 50) \u0026 (rsi14 \u003e 50))\n        )\n\n        # Weekly onay kriterleri\n        _sma50_v  = float(sma50.iloc[-1])  if not pd.isna(sma50.iloc[-1])  else None\n        _sma200_v = float(sma200.iloc[-1]) if not pd.isna(sma200.iloc[-1]) else None\n        _rsi_wok  = float(rsi14.iloc[-1])  if not pd.isna(rsi14.iloc[-1])  else None\n        _mh_wok   = float((macd_line - macd_sig).iloc[-1])\n        _cmf_wok  = float(cmf21.iloc[-1])  if not pd.isna(cmf21.iloc[-1])  else 0.0\n\n        weekly_ok = sum([\n            _sma50_v  is not None and price \u003e _sma50_v,\n            _rsi_wok  is not None and 35.0 \u003c= _rsi_wok \u003c= 75.0,\n            not pd.isna(_mh_wok) and _mh_wok \u003e 0.0,\n            _cmf_wok \u003e 0.0,\n            float(obv_val.iloc[-1]) \u003e float(obv_ema.iloc[-1]),\n            _sma200_v is not None and price \u003e _sma200_v,\n        ]) \u003e= 4\n\n        # Composite score (4 bileşen)\n        c1 = pd.Series(0.0, index=close.index)\n        c1 += (close \u003e sma200).fillna(False) * 12.0\n        c1 += ((sma50 \u003e 0) \u0026 ((close - sma50).abs() / sma50.replace(0, np.nan) * 100 \u003c 5.0)).fillna(False) * 10.0\n        c1 += ((rsi14 \u003e= SPADE_RSI_LOWER) \u0026 (rsi14 \u003c= SPADE_RSI_UPPER)).fillna(False) * 8.0\n        c1 += early_vol.fillna(False) * 12.0\n        c1 += bb_sqz.fillna(False) * 12.0\n        c1 += ((perf_w \u003e= 0.0) \u0026 (perf_w \u003c= 6.0)).fillna(False) * 5.0\n        c1 += (perf_m \u003e 11.0).fillna(False) * 8.0\n        c1 += strong_trend.fillna(False) * 8.0\n        c1 += above_vwap.fillna(False) * 8.0\n        c1 += (close \u003e open_).fillna(False) * 5.0\n        c1 += macd_hist_ris.fillna(False) * 5.0\n        c1 += cmf_pos.fillna(False) * 4.0\n        c1 += obv_bull.fillna(False) * 3.0\n        n1  = c1.clip(upper=100.0)\n\n        c2 = pd.Series(0.0, index=close.index)\n        c2 += (close \u003e sma20).fillna(False) * 8.0\n        c2 += (close \u003e sma50).fillna(False) * 8.0\n        c2 += ((rsi14 \u003e= 50.0) \u0026 (rsi14 \u003c= 74.0)).fillna(False) * 12.0\n        c2 += macd_full_bull.fillna(False) * 16.0\n        c2 += early_vol.fillna(False) * 12.0\n        c2 += (perf_d \u003e 2.0).fillna(False) * 8.0\n        c2 += (perf_w \u003e 5.0).fillna(False) * 8.0\n        c2 += (perf_m \u003c 11.0).fillna(False) * 3.0\n        c2 += strong_trend.fillna(False) * 8.0\n        c2 += above_vwap.fillna(False) * 8.0\n        c2 += rsi_x50.fillna(False) * 5.0\n        c2 += (cmf21 \u003e 0.1).fillna(False) * 4.0\n        n2  = c2.clip(upper=100.0)\n\n        c3 = pd.Series(0.0, index=close.index)\n        c3 += (close \u003e sma50).fillna(False) * 15.0\n        c3 += ((rsi14 \u003e= 44.0) \u0026 (rsi14 \u003c= 62.0)).fillna(False) * 15.0\n        c3 += (rvol \u003e 1.9).fillna(False) * 18.0\n        c3 += ((perf_w \u003e= 0.0) \u0026 (perf_w \u003c= 7.0)).fillna(False) * 8.0\n        c3 += ((perf_m \u003e= 6.0) \u0026 (perf_m \u003c= 22.0)).fillna(False) * 8.0\n        c3 += strong_trend.fillna(False) * 10.0\n        c3 += above_vwap.fillna(False) * 10.0\n        c3 += macd_hist_pos.fillna(False) * 8.0\n        c3 += cmf_strong.fillna(False) * 8.0\n        n3  = c3.clip(upper=100.0)\n\n        c4 = pd.Series(0.0, index=close.index)\n        c4 += ((sma50 \u003e 0) \u0026 ((close - sma50).abs() / sma50.replace(0, np.nan) * 100 \u003c 5.0)).fillna(False) * 18.0\n        c4 += ((rsi14 \u003e= 38.0) \u0026 (rsi14 \u003c= 56.0)).fillna(False) * 18.0\n        c4 += (perf_d.abs() \u003c= 1.5).fillna(False) * 14.0\n        c4 += (perf_w.abs() \u003c= 4.0).fillna(False) * 14.0\n        c4 += (volume \u003c 0.7 * vma20).fillna(False) * 14.0\n        c4 += bb_tsqz.fillna(False) * 14.0\n        c4 += (adx_s \u003c 20.0).fillna(False) * 8.0\n        n4  = c4.clip(upper=100.0)\n\n        # Composite \u0026 sinyal hatları\n        composite = n1 * 0.30 + n2 * 0.25 + n3 * 0.25 + n4 * 0.20\n\n        # Fake break tespiti\n        brk_event = (\n            ((close \u003e sma20) \u0026 (close.shift(1) \u003c= sma20)) |\n            ((close \u003e sma50) \u0026 (close.shift(1) \u003c= sma50))\n        )\n        fake_break = brk_event \u0026 (~high_vol | ~strong_trend | ~above_vwap)\n        adj_comp   = composite.where(~fake_break, composite * 0.60)\n\n        main_line = adj_comp.ewm(span=SPADE_M1, adjust=False).mean()\n        sig_line  = main_line.ewm(span=SPADE_M2, adjust=False).mean()\n        hist_val  = main_line - sig_line\n\n        def sv(s):\n            v = s.iloc[-1]\n            return None if pd.isna(v) else float(v)\n\n        ml = sv(main_line); sl = sv(sig_line); hv = sv(hist_val)\n        n1v = sv(n1); n2v = sv(n2); n3v = sv(n3); n4v = sv(n4)\n        comp = sv(composite)\n        adx_v  = sv(adx_s); rsi_v = sv(rsi14); rvol_v = sv(rvol)\n\n        fb  = bool(fake_break.iloc[-1])\n        ev  = bool(early_vol.iloc[-1])\n        st  = bool(strong_trend.iloc[-1])\n        mhr = bool(macd_hist_ris.iloc[-1])\n        mfb = bool(macd_full_bull.iloc[-1])\n\n        if ml is None or sl is None or hv is None:\n            return None\n\n        ml_prev    = sv(main_line.shift(1))\n        ml_cross_up = (ml_prev is not None) and (ml_prev \u003c= SPADE_BUY_LIMIT) and (ml \u003e SPADE_BUY_LIMIT)\n        ml_rising   = (ml_prev is not None) and (ml \u003e ml_prev)\n\n        # Sinyal tipleri\n        sig_b  = (n1v is not None and n1v \u003e= 65.0) and ml_cross_up and not fb\n        sig_k  = (n2v is not None and n2v \u003e= 65.0) and ev and st and bool(above_vwap.iloc[-1]) and mfb and not fb\n        sig_kp = (n3v is not None and n3v \u003e= 65.0) and ml_rising and bool(cmf_strong.iloc[-1]) and not fb\n        sig_s  = (n4v is not None and n4v \u003e= 60.0) and bool(bb_sqz.iloc[-1]) and (adx_v is not None and adx_v \u003c 20.0)\n\n        sig_count  = sum([sig_b, sig_k, sig_kp])\n        master_buy = (sig_count \u003e= 1 and ml \u003e sl and hv \u003e 0.0\n                      and ml \u003e SPADE_BUY_LIMIT and not fb and mhr)\n\n        # Onay sayacı\n        t1 = weekly_ok; t2 = not fb; t3 = ev; t4 = st\n        t5 = bool(cmf_pos.iloc[-1]); t6 = bool(above_vwap.iloc[-1]); t7 = mhr\n        t8 = (rsi_v is not None) and 35.0 \u003c= rsi_v \u003c= 75.0\n        onay_count = sum([t1, t2, t3, t4, t5, t6, t7, t8])\n        tam_onay   = (onay_count \u003e= 7) and master_buy\n\n        if not master_buy:\n            return None\n\n        sinyaller = []\n        if sig_b:  sinyaller.append(\"B\")\n        if sig_k:  sinyaller.append(\"K\")\n        if sig_kp: sinyaller.append(\"KP\")\n        if sig_s:  sinyaller.append(\"S\")\n\n        cmf_v  = float(cmf21.iloc[-1])  if not pd.isna(cmf21.iloc[-1])  else 0.0\n        vwap_v = float(vwap_s.iloc[-1]) if not pd.isna(vwap_s.iloc[-1]) else 0.0\n\n        return {\n            \"ticker\": ticker, \"price\": price,\n            \"tam_onay\": tam_onay, \"master_buy\": master_buy,\n            \"onay_count\": onay_count,\n            \"composite\": round(comp, 1) if comp else 0,\n            \"sinyaller\": \"+\".join(sinyaller) if sinyaller else \"MB\",\n            \"rsi\":  round(rsi_v,  1) if rsi_v  else 0,\n            \"adx\":  round(adx_v,  1) if adx_v  else 0,\n            \"rvol\": round(rvol_v, 2) if rvol_v else 0,\n            \"weekly_ok\": t1, \"fake_break\": fb,\n            \"n1\": round(n1v, 1) if n1v else 0,\n            \"n2\": round(n2v, 1) if n2v else 0,\n            \"n3\": round(n3v, 1) if n3v else 0,\n            \"n4\": round(n4v, 1) if n4v else 0,\n            \"ml\": round(ml, 2), \"sl\": round(sl, 2), \"hv\": round(hv, 2),\n            \"ml_prev\": round(ml_prev, 2) if ml_prev else 0,\n            \"t1_weekly\": t1, \"t2_fake\": t2, \"t3_vol\": t3, \"t4_adx\": t4,\n            \"t5_cmf\": t5, \"t6_vwap\": t6, \"t7_macd\": t7, \"t8_rsi\": t8,\n            \"sig_b\": sig_b, \"sig_k\": sig_k, \"sig_kp\": sig_kp, \"sig_s\": sig_s,\n            \"vwap\": round(vwap_v, 2), \"cmf\": round(cmf_v, 3),\n            \"early_vol\": ev, \"strong_trend\": st,\n        }\n\n    except Exception as e:\n        logger.error(f\"spade_indicators hatası {ticker}: {e}\")\n        return None\n\n\n# ============================================================\n# TOPLU TARAMA YARDIMCISI\n# ============================================================\n\ndef scan_universe(tickers: list[str], strategy_code: str,\n                  cancel_check=None) -\u003e list[dict]:\n    \"\"\"\n    Verilen hisse listesini belirtilen strateji ile tarar.\n    \n    Args:\n        tickers: Taranacak hisse listesi\n        strategy_code: Strateji kodu\n        cancel_check: İptal kontrol fonksiyonu (opsiyonel)\n    \n    Returns:\n        Eşleşen hisselerin indikatör listesi\n    \"\"\"\n    eslesen = []\n    errors  = 0\n\n    for i, ticker in enumerate(tickers):\n        if cancel_check and cancel_check():\n            logger.info(f\"Tarama iptal edildi: {i}/{len(tickers)}\")\n            break\n\n        try:\n            ind = tara_indicators(ticker)\n            if ind is None:\n                errors += 1\n                continue\n            if strateji_filtre(ind, strategy_code):\n                eslesen.append(ind)\n        except Exception as e:\n            errors += 1\n            logger.debug(f\"Tarama hatası {ticker}: {e}\")\n\n    logger.info(\n        f\"Tarama tamamlandı: {strategy_code} | \"\n        f\"{len(eslesen)} eşleşme | {errors} hata\"\n    )\n    return eslesen\n\n\ndef scan_spade_universe(tickers: list[str],\n                        cancel_check=None) -\u003e tuple[list, list]:\n    \"\"\"\n    SpadeHunter ile tüm listeyi tarar.\n    \n    Returns:\n        (tam_onay_list, master_buy_list)\n    \"\"\"\n    tam_onay_list  = []\n    master_buy_list = []\n    errors = 0\n\n    for i, ticker in enumerate(tickers):\n        if cancel_check and cancel_check():\n            logger.info(f\"SpadeHunter iptal: {i}/{len(tickers)}\")\n            break\n\n        try:\n            sonuc = spade_indicators(ticker)\n            if sonuc is None:\n                continue\n            if sonuc[\"tam_onay\"]:\n                tam_onay_list.append(sonuc)\n            elif sonuc[\"master_buy\"]:\n                master_buy_list.append(sonuc)\n        except Exception as e:\n            errors += 1\n            logger.debug(f\"SpadeHunter hata {ticker}: {e}\")\n\n    # Composite'e göre sırala\n    tam_onay_list.sort(key=lambda x: x[\"composite\"], reverse=True)\n    master_buy_list.sort(key=lambda x: x[\"composite\"], reverse=True)\n\n    logger.info(\n        f\"SpadeHunter: {len(tam_onay_list)} tam onay | \"\n        f\"{len(master_buy_list)} master buy | {errors} hata\"\n    )\n    return tam_onay_list, master_buy_list\n```\n\n---\n\n## ✅ SCANNER.PY TAMAMLANDI\n\nBu dosya `core/modules/scanner.py` olarak kaydedilmeli.\n\n### Özet — Ne taşındı:\n\n| bot.py Fonksiyonu | scanner.py'de |\n|---|---|\n| `calc_rsi/ema/sma/macd/adx/atr` | ✅ Taşındı |\n| `calc_bollinger_width` | ✅ Taşındı |\n| `detect_divergence` | ✅ Taşındı |\n| `detect_market_regime` | ✅ Taşındı |\n| `calc_risk_management` | ✅ Taşındı |\n| `calc_gap_analysis` | ✅ Taşındı |\n| `calc_volume_momentum` | ✅ Taşındı |\n| `calc_mtf_score` | ✅ Taşındı |\n| `tara_indicators` | ✅ Taşındı |\n| `strateji_filtre` (18 strateji) | ✅ Taşındı |\n| `spade_indicators` | ✅ Taşındı |\n| `get_data/fetch_yahoo_direct` | ✅ Taşındı |\n| `scan_universe` | 🆕 Yeni (agent'ler için) |\n| `scan_spade_universe` | 🆕 Yeni (agent'ler için) |\n\n---\n\n## SONRAKİ ADIM\n\n`scanner.py` dosyasını oluşturduktan sonra bana söyleyin:\n\n```\n1️⃣ scanner.py oluşturuldu → core/modules/news.py'ye geçelim\n2️⃣ Hata var → yapıştırın, düzeltelim  \n3️⃣ Direkt models/gemini_client.py'ye atlamak istiyorum\n```\n\n**Hangisini tercih edersiniz?**"])</script><script>self.__next_f.push([1,"1a:T4573,"])</script><script>self.__next_f.push([1,"Harika, `bot.py` kodunun tamamını aldım. Bu, projenin mevcut durumunu tam olarak anlamam için kritikti ve OCR'dan çok daha değerli. Beklediğim gibi, içinde çok güçlü ve çeşitli yetenekler barındırıyor.\n\nŞimdi, plana harfiyen sadık kalarak **FAZ 2: Mevcut bot.py'nin Modülerleştirilmesi** adımına geçiyoruz. Amacımız, bu büyük ve karmaşık dosyayı, her biri tek bir işten sorumlu, temiz, okunabilir ve yönetilebilir modüllere ayırmak.\n\n---\n\n## FAZ 2: KOD MİGRASYONU VE MODÜLERLEŞTİRME\n\nBu fazda, `bot.py` içindeki tüm **hesaplama, tarama, haber toplama, risk yönetimi ve veri çekme** mantığını `core/modules/` klasörüne taşıyacağız.\n\n**ÖNEMLİ:** AI (`gemini_ask`, `groq_ask`) ve Telegram (`@bot.message_handler`) ile ilgili kısımları **şimdilik ellemeyeceğiz**. Onlar sonraki fazların konusu.\n\nİşte adım adım yapacaklarımız:\n\n### Adım 2.1: Veri Çekme Modülü (`core/modules/data_fetcher.py`)\n\nBu yeni modül, Yahoo Finance'dan veri çekme ve haftalık veriye dönüştürme gibi temel işlemlerden sorumlu olacak.\n\n```python\n# trading_ai_system/core/modules/data_fetcher.py\n\nimport pandas as pd\nimport requests\nfrom loguru import logger\nimport time\n\n# Not: Veri çekme işlemleri yavaş olabileceğinden, gelecekte buraya\n# daha gelişmiş bir cache mekanizması (örn: Redis) ekleyebiliriz.\n# Şimdilik doğrudan Yahoo'dan çekiyoruz.\n\nYAHOO_HEADERS = {\n    \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\",\n    \"Accept\": \"application/json,text/html,*/*\",\n    \"Accept-Language\": \"tr-TR,tr;q=0.9\",\n    \"Referer\": \"https://finance.yahoo.com/\",\n}\n\ndef _fetch_yahoo_direct(ticker: str, interval: str = \"1d\", range_: str = \"2y\") -\u003e pd.DataFrame:\n    \"\"\"Belirtilen hisse senedi için Yahoo Finance'dan OHLCV verilerini çeker.\"\"\"\n    url = (\n        f\"https://query2.finance.yahoo.com/v8/finance/chart/{ticker}.IS?\"\n        f\"interval={interval}\u0026range={range_}\"\n    )\n    try:\n        # Veri çekme işlemlerinde çakışmayı önlemek için küçük bir bekleme\n        time.sleep(0.1) \n        resp = requests.get(url, headers=YAHOO_HEADERS, timeout=15)\n        \n        if resp.status_code != 200:\n            logger.warning(f\"Yahoo API hatası ({ticker}): Status {resp.status_code}\")\n            return pd.DataFrame()\n\n        data = resp.json()\n        result = data.get(\"chart\", {}).get(\"result\", [])\n        if not result:\n            logger.warning(f\"Yahoo API'den {ticker} için veri gelmedi.\")\n            return pd.DataFrame()\n\n        r = result[0]\n        timestamps = r.get(\"timestamp\", [])\n        ohlcv = r.get(\"indicators\", {}).get(\"quote\", [{}])[0]\n\n        if not timestamps or not all(k in ohlcv for k in ['open', 'high', 'low', 'close', 'volume']):\n            logger.warning(f\"Yahoo API'den {ticker} için eksik veri geldi.\")\n            return pd.DataFrame()\n        \n        df = pd.DataFrame({\n            \"datetime\": pd.to_datetime(timestamps, unit=\"s\"),\n            \"Open\": ohlcv.get(\"open\", []),\n            \"High\": ohlcv.get(\"high\", []),\n            \"Low\": ohlcv.get(\"low\", []),\n            \"Close\": ohlcv.get(\"close\", []),\n            \"Volume\": ohlcv.get(\"volume\", []),\n        })\n\n        df = df.set_index(\"datetime\").sort_index()\n        df.index = df.index.tz_localize(None) # Zaman dilimi bilgisini kaldır\n\n        for col in [\"Open\", \"High\", \"Low\", \"Close\", \"Volume\"]:\n            df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n\n        return df.dropna(subset=[\"Close\", \"Volume\"])\n\n    except requests.exceptions.RequestException as e:\n        logger.error(f\"Yahoo API bağlantı hatası ({ticker}): {e}\")\n        return pd.DataFrame()\n    except Exception as e:\n        logger.error(f\"Yahoo veri işleme hatası ({ticker}): {e}\")\n        return pd.DataFrame()\n\ndef resample_to_weekly(df_daily: pd.DataFrame) -\u003e pd.DataFrame:\n    \"\"\"Günlük veriyi haftalık veriye dönüştürür.\"\"\"\n    if df_daily.empty:\n        return pd.DataFrame()\n    \n    df_weekly = df_daily.resample(\"W\").agg({\n        \"Open\": \"first\",\n        \"High\": \"max\",\n        \"Low\": \"min\",\n        \"Close\": \"last\",\n        \"Volume\": \"sum\"\n    }).dropna(subset=[\"Close\"])\n    df_weekly.index.name = \"datetime\"\n    return df_weekly\n\ndef get_data(ticker: str) -\u003e tuple[pd.DataFrame, pd.DataFrame]:\n    \"\"\"\n    Bir hisse senedi için günlük ve haftalık verileri çeker.\n    FAZ 1'deki veritabanı yapısına uygun olarak cache'leme ileride eklenecektir.\n    \"\"\"\n    logger.debug(f\"{ticker} için veri çekiliyor...\")\n    \n    # Şimdilik her seferinde canlı veri çekiyoruz.\n    df_daily = _fetch_yahoo_direct(ticker, interval=\"1d\", range_=\"2y\")\n    \n    if df_daily.empty:\n        logger.warning(f\"{ticker} için günlük veri çekilemedi.\")\n        return pd.DataFrame(), pd.DataFrame()\n        \n    # Haftalık veri, günlükten hesaplanarak tutarlılık sağlanır.\n    df_weekly = resample_to_weekly(df_daily)\n    \n    logger.success(f\"{ticker} için veri çekildi. Günlük: {len(df_daily)} bar, Haftalık: {len(df_weekly)} bar.\")\n    return df_daily, df_weekly\n\n```\n\n### Adım 2.2: Tarama ve İndikatör Modülü (`core/modules/scanner.py`)\n\n`bot.py`'deki tüm `calc_*` fonksiyonları, strateji mantıkları (`spade_indicators` ve `scan_all_stocks` içindeki analizler) buraya taşınacak. Bu dosya, sistemin \"hesaplama motoru\" olacak.\n\n```python\n# trading_ai_system/core/modules/scanner.py\n\nimport pandas as pd\nimport numpy as np\nimport ta\nfrom loguru import logger\n\n# ==============================================================================\n# TEMEL İNDİKATÖR HESAPLAMALARI\n# (Orijinal bot.py'den doğrudan taşınan saf fonksiyonlar)\n# ==============================================================================\n\ndef calc_rsi(series: pd.Series, length: int = 14) -\u003e pd.Series:\n    delta = series.diff()\n    gain = delta.clip(lower=0)\n    loss = -delta.clip(upper=0)\n    avg_gain = gain.ewm(com=length - 1, min_periods=length).mean()\n    avg_loss = loss.ewm(com=length - 1, min_periods=length).mean()\n    rs = avg_gain / avg_loss.replace(0, np.nan)\n    return 100 - (100 / (1 + rs))\n\ndef calc_ema(series: pd.Series, length: int) -\u003e pd.Series:\n    return series.ewm(span=length, adjust=False).mean()\n\ndef calc_sma(series: pd.Series, length: int) -\u003e pd.Series:\n    return series.rolling(window=length).mean()\n\ndef calc_macd(series: pd.Series, fast: int = 12, slow: int = 26, signal: int = 9) -\u003e tuple[pd.Series, pd.Series]:\n    ema_fast = calc_ema(series, fast)\n    ema_slow = calc_ema(series, slow)\n    macd_line = ema_fast - ema_slow\n    signal_line = macd_line.ewm(span=signal, adjust=False).mean()\n    return macd_line, signal_line\n\ndef calc_adx(high: pd.Series, low: pd.Series, close: pd.Series, period: int = 14) -\u003e pd.Series:\n    return ta.trend.adx(high, low, close, window=period)\n\ndef calc_bollinger_bands(series: pd.Series, period: int = 20, std_mult: int = 2) -\u003e tuple[pd.Series, pd.Series, pd.Series]:\n    sma = series.rolling(period).mean()\n    std = series.rolling(period).std()\n    upper = sma + std_mult * std\n    lower = sma - std_mult * std\n    return upper, sma, lower\n\n# ... Orijinal bot.py'deki diğer tüm `calc_*` fonksiyonları buraya eklenebilir ...\n# Örneğin: calc_atr, calc_bollinger_width, perf_pct, vb.\n\n# ==============================================================================\n# KOMPLEKS TARAMA STRATEJİLERİ\n# (Bu fonksiyonlar yukarıdaki temel hesaplamaları kullanarak analiz yapar)\n# ==============================================================================\n\ndef run_ema_rsi_strategy(df_daily: pd.DataFrame, df_weekly: pd.DataFrame, ema_params: dict) -\u003e list:\n    \"\"\"\n    Orijinal /check komutunun mantığını çalıştırır.\n    Günlük ve haftalık periyotlarda EMA kesişimlerini ve RSI durumunu analiz eder.\n    \"\"\"\n    signals = []\n    \n    # --- GÜNLÜK ANALİZ ---\n    if not df_daily.empty and len(df_daily) \u003e max(ema_params['daily']):\n        close_d = df_daily['Close']\n        rsi_d = calc_rsi(close_d, 14).iloc[-1]\n        \n        ema_s_d = calc_ema(close_d, ema_params['daily'][0])\n        ema_l_d = calc_ema(close_d, ema_params['daily'][1])\n\n        if len(ema_s_d) \u003e 1 and len(ema_l_d) \u003e 1:\n            cross_up = ema_s_d.iloc[-2] \u003c= ema_l_d.iloc[-2] and ema_s_d.iloc[-1] \u003e ema_l_d.iloc[-1]\n            trend_up = ema_s_d.iloc[-1] \u003e ema_l_d.iloc[-1]\n            \n            if cross_up:\n                signals.append(f\"⬆️ GÜNLÜK AL: EMA Taze Kesişim ({ema_params['daily'][0]}/{ema_params['daily'][1]})\")\n            elif trend_up and 40 \u003c= rsi_d \u003c= 65:\n                 signals.append(f\"📈 GÜNLÜK YUKARI TREND: EMA({ema_params['daily'][0]}\u003e{ema_params['daily'][1]}) ve RSI Uyumlu\")\n\n    # --- HAFTALIK ANALİZ ---\n    if not df_weekly.empty and len(df_weekly) \u003e max(ema_params['weekly']):\n        close_w = df_weekly['Close']\n        rsi_w = calc_rsi(close_w, 14).iloc[-1]\n        \n        ema_s_w = calc_ema(close_w, ema_params['weekly'][0])\n        ema_l_w = calc_ema(close_w, ema_params['weekly'][1])\n        \n        if len(ema_s_w) \u003e 1 and len(ema_l_w) \u003e 1:\n            cross_up_w = ema_s_w.iloc[-2] \u003c= ema_l_w.iloc[-2] and ema_s_w.iloc[-1] \u003e ema_l_w.iloc[-1]\n            \n            if cross_up_w:\n                signals.append(f\"🚀 HAFTALIK GÜÇLÜ AL: EMA Taze Kesişim ({ema_params['weekly'][0]}/{ema_params['weekly'][1]})\")\n\n    return signals\n\n\ndef run_spade_hunter_strategy(df_weekly: pd.DataFrame) -\u003e dict | None:\n    \"\"\"\n    Orijinal /tara spade komutunun mantığını çalıştırır.\n    Kompozit skorlama sistemini kullanarak alım sinyali üretir.\n    NOT: Bu fonksiyon çok karmaşık olduğu için basitleştirilmiş bir iskelettir.\n    Orijinal 'c1, c2, c3, c4' mantığı buraya detaylı olarak aktarılmalıdır.\n    \"\"\"\n    if df_weekly.empty or len(df_weekly) \u003c 60:\n        return None\n        \n    logger.info(\"Spade Hunter stratejisi çalıştırılıyor...\")\n    # Orijinal bot.py'deki tüm 'c1, c2, c3, c4' ve 'composite' hesaplamaları\n    # bu fonksiyonun içine taşınmalıdır. Bu, kodun okunabilirliğini\n    # ve test edilebilirliğini artıracaktır.\n    # Örnek bir dönüş değeri:\n    # return {\n    #     \"ticker\": \"THYAO\", \"price\": 250.5, \"tam_onay\": True, \n    #     \"master_buy\": True, \"composite\": 85.0, \"sinyaller\": \"B+K\", ...\n    # }\n    \n    # Şimdilik sadece bir iskelet olarak bırakıyorum.\n    # Bu fonksiyonun içini doldurmak, modülerleştirmenin en önemli adımlarından biridir.\n    return None\n\n```\n\n### Adım 2.3: Haber Toplama Modülü (`core/modules/news.py`)\n\n`bot.py`'deki tüm RSS ve KAP ile ilgili fonksiyonlar buraya gelecek.\n\n```python\n# trading_ai_system/core/modules/news.py\n\nimport feedparser\nimport requests\nimport xml.etree.ElementTree as ET\nfrom loguru import logger\nfrom config.settings import settings # Gelecekte RSS_FEEDS'i buradan alabiliriz.\n\n# İleriye dönük not: Bu RSS listesini de YAML konfigürasyonuna taşıyabiliriz.\nRSS_FEEDS = {\n    \"global\": [\n        (\"Reuters\", \"https://feeds.reuters.com/reuters/businessNews\"),\n        (\"CNBC\", \"https://search.cnbc.com/rs/search/combinedcms/view.xml?partnerId=wrss01\u0026id=15839135\"),\n    ],\n    \"bist\": [\n        (\"Google Borsa\", \"https://news.google.com/rss/search?q=borsa+istanbul+BIST+hisse\u0026hl=tr\u0026gl=TR\u0026ceid=TR:tr\"),\n        (\"Bloomberg HT\", \"https://www.bloomberght.com/rss\"),\n    ],\n    \"kap\": [\n        (\"KAP\", \"https://www.kap.org.tr/tr/rss/bildirim\"),\n    ],\n}\n\ndef fetch_rss(url: str, max_items: int = 5, timeout: int = 10) -\u003e list:\n    \"\"\"Verilen bir URL'den RSS akışını çeker ve parse eder.\"\"\"\n    try:\n        headers = {\"User-Agent\": \"Mozilla/5.0 (compatible; BISTBot/1.0)\"}\n        response = requests.get(url, timeout=timeout, headers=headers)\n        response.raise_for_status()\n        \n        # Google News için özel durum\n        if \"news.google.com\" in url:\n            feed = feedparser.parse(response.content)\n            return [\n                {\"title\": entry.title, \"link\": entry.link, \"pub\": entry.published, \"desc\": entry.get(\"summary\", \"\")}\n                for entry in feed.entries[:max_items]\n            ]\n        \n        # Diğer RSS'ler (XML)\n        root = ET.fromstring(response.content)\n        items = []\n        for item in root.findall(\".//item\")[:max_items]:\n            title = item.findtext(\"title\", \"\").strip()\n            if title:\n                items.append({\n                    \"title\": title,\n                    \"desc\": item.findtext(\"description\", \"\").strip()[:200],\n                    \"pub\": item.findtext(\"pubDate\", \"\").strip(),\n                    \"link\": item.findtext(\"link\", \"\").strip(),\n                })\n        return items\n    except Exception as e:\n        logger.error(f\"RSS çekme hatası ({url}): {e}\")\n        return []\n\ndef collect_news(categories: list = None, ticker: str = None) -\u003e list:\n    \"\"\"Belirtilen kategorilerde ve hisse için haberleri toplar.\"\"\"\n    if categories is None:\n        categories = [\"global\", \"bist\"]\n    \n    all_news = []\n    for cat in categories:\n        for name, url in RSS_FEEDS.get(cat, []):\n            items = fetch_rss(url)\n            for item in items:\n                item[\"source\"] = name\n                item[\"category\"] = cat\n                all_news.append(item)\n\n    if ticker:\n        ticker_upper = ticker.upper()\n        # KAP haberlerini ekle\n        kap_items = fetch_rss(RSS_FEEDS[\"kap\"][0][1], max_items=25)\n        for item in kap_items:\n            if ticker_upper in item.get(\"title\", \"\").upper():\n                item[\"source\"] = \"KAP\"\n                item[\"category\"] = \"kap\"\n                all_news.insert(0, item) # KAP haberleri en başa\n\n        # İlgili haberleri filtrele\n        filtered = [\n            n for n in all_news \n            if ticker_upper in (n.get(\"title\", \"\") + n.get(\"desc\", \"\")).upper()\n        ]\n        return filtered\n\n    # Önem sırasına göre sırala (basit anahtar kelime)\n    all_news.sort(key=lambda x: \"kritik\" in x['title'].lower(), reverse=True)\n    return all_news\n\ndef news_to_text(news_list: list, max_items: int = 10) -\u003e str:\n    \"\"\"Haber listesini AI modeline gönderilecek metne dönüştürür.\"\"\"\n    lines = []\n    for i, n in enumerate(news_list[:max_items]):\n        lines.append(f\"{i+1}. [{n.get('source', '?')}] {n.get('title', 'Başlık Yok')}\")\n    return \"\\n\".join(lines) if lines else \"Haber bulunamadı.\"\n```\n\n### Adım 2.4: Risk Yönetimi Modülü (`core/modules/risk_manager.py`)\n\n`bot.py`'deki `/karzarar` komutunun tüm modları (trade hesabı, risk, pozisyon boyutu) buraya fonksiyon olarak taşınacak.\n\n```python\n# trading_ai_system/core/modules/risk_manager.py\n\nfrom loguru import logger\n\ndef calculate_trade_pnl(alis: float, satis: float, adet: float) -\u003e dict:\n    \"\"\"Bir trade'in kar/zararını hesaplar.\"\"\"\n    if not all([alis \u003e 0, satis \u003e 0, adet \u003e 0]):\n        return {\"error\": \"Tüm değerler sıfırdan büyük olmalı.\"}\n        \n    alis_top = alis * adet\n    satis_top = satis * adet\n    kaz_tl = satis_top - alis_top\n    kaz_pct = (satis - alis) / alis\n    komisyon = (alis_top + satis_top) * 0.001 # Ortalama %0.1 komisyon varsayımı\n    net_kaz = kaz_tl - komisyon\n    \n    return {\n        \"alis_top\": alis_top,\n        \"satis_top\": satis_top,\n        \"kaz_tl\": kaz_tl,\n        \"kaz_pct\": kaz_pct,\n        \"komisyon\": komisyon,\n        \"net_kaz\": net_kaz,\n        \"yon\": \"KÂR\" if kaz_tl \u003e= 0 else \"ZARAR\"\n    }\n\ndef calculate_position_size(portfolio: float, risk_pct: float, giris: float, stop: float) -\u003e dict:\n    \"\"\"Verilen risk parametrelerine göre ideal pozisyon boyutunu hesaplar.\"\"\"\n    if not all([portfolio \u003e 0, risk_pct \u003e 0, giris \u003e stop \u003e 0]):\n        return {\"error\": \"Geçersiz parametreler.\"}\n    \n    risk_pct_decimal = risk_pct / 100\n    max_risk_amount = portfolio * risk_pct_decimal\n    risk_per_share = giris - stop\n    \n    if risk_per_share \u003c= 0:\n        return {\"error\": \"Giriş fiyatı stop'tan büyük olmalı.\"}\n        \n    adet = max_risk_amount / risk_per_share\n    pozisyon_degeri = adet * giris\n    \n    return {\n        \"max_risk_amount\": max_risk_amount,\n        \"risk_per_share\": risk_per_share,\n        \"adet\": adet,\n        \"pozisyon_degeri\": pozisyon_degeri,\n        \"portfoy_yuzdesi\": (pozisyon_degeri / portfolio) * 100,\n        \"hedef1\": giris + (risk_per_share * 2), # 1:2 R/R\n        \"hedef2\": giris + (risk_per_share * 3), # 1:3 R/R\n    }\n\ndef analyze_open_position(alis: float, adet: float, guncel: float) -\u003e dict:\n    \"\"\"Açık bir pozisyonun anlık kar/zarar durumunu hesaplar.\"\"\"\n    if not all([alis \u003e 0, adet \u003e 0, guncel \u003e 0]):\n        return {\"error\": \"Tüm değerler sıfırdan büyük olmalı.\"}\n        \n    kaz_tl = (guncel - alis) * adet\n    kaz_pct = (guncel - alis) / alis\n    \n    return {\n        \"kaz_tl\": kaz_tl,\n        \"kaz_pct\": kaz_pct,\n        \"yon\": \"KÂR\" if kaz_tl \u003e= 0 else \"ZARAR\",\n        \"stop\": alis * 0.97, # %3 örnek stop\n        \"hedef1\": alis * 1.10, # %10 örnek hedef\n        \"hedef2\": alis * 1.20, # %20 örnek hedef\n    }\n```\n\n---\n\n## SONRAKİ ADIMLAR\n\n1.  **Yukarıdaki 4 yeni dosyayı** (`data_fetcher.py`, `scanner.py`, `news.py`, `risk_manager.py`) projenizdeki `core/modules/` klasörünün içine oluşturun ve kodları yapıştırın.\n2.  **`bot.py` dosyasını SİLİN!** Bu önemli bir adımdır. Artık monolitik yapıdan kurtulduk. İçindeki mantığı yeni evlerine taşıdık.\n3.  `requirements.txt` dosyanıza `ta` kütüphanesini e