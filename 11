17L19 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="absolute inset-0 m-auto opacity-100 transition-opacity duration-300"><path d="M19.4 20H9.6C9.26863 20 9 19.7314 9 19.4V9.6C9 9.26863 9.26863 9 9.6 9H19.4C19.7314 9 20 9.26863 20 9.6V19.4C20 19.7314 19.7314 20 19.4 20Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 9V4.6C15 4.26863 14.7314 4 14.4 4H4.6C4.26863 4 4 4.26863 4 4.6V14.4C4 14.7314 4.26863 15 4.6 15H9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg></button></div><div class="code-block_container__lbMX4"><pre class="m-0 whitespace-pre-wrap rounded-none px-4 py-3 font-mono text-[#24292e] dark:text-[#e1e4e8]"><code class="text-[11px] leading-normal sm:text-[13px]"># core/modules/database.py
&quot;&quot;&quot;
PostgreSQL veritabanı bağlantı ve yönetim katmanı.
SQLAlchemy ile bağlantı havuzu yönetimi yapar.
Agent hafızası ve trade verileri için tablo oluşturma/yönetme işlemlerini içerir.
&quot;&quot;&quot;

from sqlalchemy import (
    create_engine,
    text,
    Column,
    Integer,
    String,
    Float,
    DateTime,
    Text,
    Boolean,
    JSON,
)
from sqlalchemy.orm import sessionmaker, declarative_base
from sqlalchemy.pool import QueuePool
from datetime import datetime
from loguru import logger

from config.settings import settings

# SQLAlchemy Base
Base = declarative_base()


# ============================================================
# VERİTABANI TABLOLARI (ORM Modelleri)
# ============================================================

class ScanResult(Base):
    &quot;&quot;&quot;Tarama sonuçları tablosu.&quot;&quot;&quot;
    __tablename__ = &quot;scan_results&quot;

    id = Column(Integer, primary_key=True, autoincrement=True)
    scan_date = Column(DateTime, default=datetime.now, nullable=False)
    strategy_name = Column(String(100), nullable=False)
    symbol = Column(String(20), nullable=False)
    signal_type = Column(String(20))  # BUY, SELL, NEUTRAL
    signal_strength = Column(Float)   # 0.0 - 1.0
    price_at_signal = Column(Float)
    indicators = Column(JSON)         # RSI, MACD vb. değerler
    ai_interpretation = Column(Text)  # Agent&#x27;in yorumu
    created_at = Column(DateTime, default=datetime.now)


class TradeBook(Base):
    &quot;&quot;&quot;Trade takip tablosu.&quot;&quot;&quot;
    __tablename__ = &quot;trade_book&quot;

    id = Column(Integer, primary_key=True, autoincrement=True)
    symbol = Column(String(20), nullable=False)
    entry_date = Column(DateTime)
    entry_price = Column(Float)
    exit_date = Column(DateTime)
    exit_price = Column(Float)
    position_size = Column(Float)
    pnl = Column(Float)
    pnl_percentage = Column(Float)
    strategy_name = Column(String(100))
    notes = Column(Text)
    status = Column(String(20), default=&quot;OPEN&quot;)  # OPEN, CLOSED, CANCELLED
    created_at = Column(DateTime, default=datetime.now)
    updated_at = Column(DateTime, default=datetime.now, onupdate=datetime.now)


class AgentDecision(Base):
    &quot;&quot;&quot;Agent karar hafızası tablosu.&quot;&quot;&quot;
    __tablename__ = &quot;agent_decisions&quot;

    id = Column(Integer, primary_key=True, autoincrement=True)
    agent_name = Column(String(50), nullable=False)
    decision_type = Column(String(50))  # ANALYSIS, STRATEGY, ALERT, REVIEW
    decision_date = Column(DateTime, default=datetime.now)
    context = Column(JSON)              # Karar anındaki bağlam bilgisi
    decision = Column(Text)             # Kararın kendisi
    confidence = Column(Float)          # Güven skoru 0-1
    outcome = Column(String(20))        # CORRECT, WRONG, PENDING, UNKNOWN
    outcome_notes = Column(Text)
    created_at = Column(DateTime, default=datetime.now)
    updated_at = Column(DateTime, default=datetime.now, onupdate=datetime.now)


class StrategyPerformance(Base):
    &quot;&quot;&quot;Strateji performans takip tablosu.&quot;&quot;&quot;
    __tablename__ = &quot;strategy_performance&quot;

    id = Column(Integer, primary_key=True, autoincrement=True)
    strategy_name = Column(String(100), nullable=False)
    evaluation_date = Column(DateTime, default=datetime.now)
    total_signals = Column(Integer, default=0)
    successful_signals = Column(Integer, default=0)
    failed_signals = Column(Integer, default=0)
    avg_return = Column(Float)
    win_rate = Column(Float)
    max_drawdown = Column(Float)
    sharpe_ratio = Column(Float)
    notes = Column(Text)
    is_active = Column(Boolean, default=True)
    created_at = Column(DateTime, default=datetime.now)


class MarketContext(Base):
    &quot;&quot;&quot;Günlük piyasa bağlamı tablosu (Dinamik Skill için).&quot;&quot;&quot;
    __tablename__ = &quot;market_context&quot;

    id = Column(Integer, primary_key=True, autoincrement=True)
    context_date = Column(DateTime, default=datetime.now, nullable=False)
    market_regime = Column(String(50))    # BULL, BEAR, SIDEWAYS, VOLATILE
    xu100_close = Column(Float)
    xu100_change_pct = Column(Float)
    usdtry = Column(Float)
    vix_level = Column(Float)
    sector_leaders = Column(JSON)         # En güçlü sektörler
    key_news_summary = Column(Text)       # Günün önemli haberleri özeti
    active_strategies = Column(JSON)      # O gün aktif stratejiler
    agent_consensus = Column(Text)        # Agent&#x27;lerin ortak görüşü
    created_at = Column(DateTime, default=datetime.now)


class LessonLearned(Base):
    &quot;&quot;&quot;Öğrenilmiş dersler tablosu - Uzun vadeli hafıza.&quot;&quot;&quot;
    __tablename__ = &quot;lessons_learned&quot;

    id = Column(Integer, primary_key=True, autoincrement=True)
    lesson_date = Column(DateTime, default=datetime.now)
    agent_name = Column(String(50))
    category = Column(String(50))     # PATTERN, STRATEGY, MARKET_BEHAVIOR, ERROR
    lesson = Column(Text, nullable=False)
    evidence = Column(JSON)           # Destekleyici veri
    importance = Column(Integer, default=5)  # 1-10
    times_validated = Column(Integer, default=0)  # Kaç kez doğrulandı
    is_active = Column(Boolean, default=True)
    created_at = Column(DateTime, default=datetime.now)
    updated_at = Column(DateTime, default=datetime.now, onupdate=datetime.now)


# ============================================================
# VERİTABANI YÖNETİCİSİ
# ============================================================

class DatabaseManager:
    &quot;&quot;&quot;
    PostgreSQL veritabanı bağlantı ve operasyon yöneticisi.
    Singleton pattern ile tek bir bağlantı havuzu kullanır.
    &quot;&quot;&quot;

    _instance = None
    _engine = None
    _session_factory = None

    def __new__(cls):
        if cls._instance is None:
            cls._instance = super().__new__(cls)
            cls._instance._initialize()
        return cls._instance

    def _initialize(self):
        &quot;&quot;&quot;Veritabanı engine ve session factory oluşturur.&quot;&quot;&quot;
        try:
            self._engine = create_engine(
                settings.database_url,
                poolclass=QueuePool,
                pool_size=5,
                max_overflow=10,
                pool_pre_ping=True,  # Bağlantı sağlığını kontrol et
                echo=False,
            )
            self._session_factory = sessionmaker(bind=self._engine)
            logger.info(
                f&quot;Veritabanı bağlantısı kuruldu: &quot;
                f&quot;{settings.db_host}:{settings.db_port}/{settings.db_name}&quot;
            )
        except Exception as e:
            logger.error(f&quot;Veritabanı bağlantı hatası: {e}&quot;)
            raise

    def create_tables(self):
        &quot;&quot;&quot;Tüm tabloları oluşturur (yoksa).&quot;&quot;&quot;
        try:
            Base.metadata.create_all(self._engine)
            logger.info(&quot;Veritabanı tabloları oluşturuldu/kontrol edildi&quot;)
        except Exception as e:
            logger.error(f&quot;Tablo oluşturma hatası: {e}&quot;)
            raise

    def get_session(self):
        &quot;&quot;&quot;Yeni bir veritabanı oturumu döndürür.&quot;&quot;&quot;
        return self._session_factory()

    def health_check(self) -&gt; dict:
        &quot;&quot;&quot;Veritabanı sağlık kontrolü.&quot;&quot;&quot;
        try:
            with self._engine.connect() as conn:
                result = conn.execute(text(&quot;SELECT 1&quot;))
                result.fetchone()

            # Tablo sayısını kontrol et
            with self._engine.connect() as conn:
                result = conn.execute(text(
                    &quot;SELECT count(*) FROM information_schema.tables &quot;
                    &quot;WHERE table_schema = &#x27;public&#x27;&quot;
                ))
                table_count = result.fetchone()[0]

            return {
                &quot;status&quot;: &quot;OK&quot;,
                &quot;host&quot;: settings.db_host,
                &quot;database&quot;: settings.db_name,
                &quot;tables&quot;: table_count,
            }
        except Exception as e:
            return {
                &quot;status&quot;: &quot;HATA&quot;,
                &quot;error&quot;: str(e),
            }

    # --- Yardımcı CRUD Operasyonları ---

    def save_scan_result(self, scan_data: dict):
        &quot;&quot;&quot;Tarama sonucunu kaydeder.&quot;&quot;&quot;
        session = self.get_session()
        try:
            record = ScanResult(**scan_data)
            session.add(record)
            session.commit()
            logger.debug(f&quot;Tarama sonucu kaydedildi: {scan_data.get(&#x27;symbol&#x27;)}&quot;)
        except Exception as e:
            session.rollback()
            logger.error(f&quot;Tarama kayıt hatası: {e}&quot;)
        finally:
            session.close()

    def save_agent_decision(self, decision_data: dict):
        &quot;&quot;&quot;Agent kararını kaydeder.&quot;&quot;&quot;
        session = self.get_session()
        try:
            record = AgentDecision(**decision_data)
            session.add(record)
            session.commit()
            logger.debug(
                f&quot;Agent kararı kaydedildi: {decision_data.get(&#x27;agent_name&#x27;)}&quot;
            )
        except Exception as e:
            session.rollback()
            logger.error(f&quot;Karar kayıt hatası: {e}&quot;)
        finally:
            session.close()

    def save_market_context(self, context_data: dict):
        &quot;&quot;&quot;Günlük piyasa bağlamını kaydeder.&quot;&quot;&quot;
        session = self.get_session()
        try:
            record = MarketContext(**context_data)
            session.add(record)
            session.commit()
            logger.debug(&quot;Piyasa bağlamı kaydedildi&quot;)
        except Exception as e:
            session.rollback()
            logger.error(f&quot;Bağlam kayıt hatası: {e}&quot;)
        finally:
            session.close()

    def save_lesson(self, lesson_data: dict):
        &quot;&quot;&quot;Öğrenilmiş ders kaydeder.&quot;&quot;&quot;
        session = self.get_session()
        try:
            record = LessonLearned(**lesson_data)
            session.add(record)
            session.commit()
            logger.debug(f&quot;Ders kaydedildi: {lesson_data.get(&#x27;category&#x27;)}&quot;)
        except Exception as e:
            session.rollback()
            logger.error(f&quot;Ders kayıt hatası: {e}&quot;)
        finally:
            session.close()

    def get_recent_decisions(self, agent_name: str, days: int = 7, limit: int = 20) -&gt; list:
        &quot;&quot;&quot;Belirli bir agent&#x27;in son kararlarını getirir.&quot;&quot;&quot;
        session = self.get_session()
        try:
            results = (
                session.query(AgentDecision)
                .filter(AgentDecision.agent_name == agent_name)
                .order_by(AgentDecision.decision_date.desc())
                .limit(limit)
                .all()
            )
            return results
        except Exception as e:
            logger.error(f&quot;Karar sorgulama hatası: {e}&quot;)
            return []
        finally:
            session.close()

    def get_active_lessons(self, agent_name: str = None, limit: int = 10) -&gt; list:
        &quot;&quot;&quot;Aktif öğrenilmiş dersleri getirir.&quot;&quot;&quot;
        session = self.get_session()
        try:
            query = (
                session.query(LessonLearned)
                .filter(LessonLearned.is_active == True)
                .order_by(LessonLearned.importance.desc())
            )
            if agent_name:
                query = query.filter(LessonLearned.agent_name == agent_name)
            return query.limit(limit).all()
        except Exception as e:
            logger.error(f&quot;Ders sorgulama hatası: {e}&quot;)
            return []
        finally:
            session.close()

    def get_latest_market_context(self) -&gt; MarketContext | None:
        &quot;&quot;&quot;En son piyasa bağlamını getirir.&quot;&quot;&quot;
        session = self.get_session()
        try:
            return (
                session.query(MarketContext)
                .order_by(MarketContext.context_date.desc())
                .first()
            )
        except Exception as e:
            logger.error(f&quot;Bağlam sorgulama hatası: {e}&quot;)
            return None
        finally:
            session.close()

    def get_strategy_performance(self, strategy_name: str = None) -&gt; list:
        &quot;&quot;&quot;Strateji performanslarını getirir.&quot;&quot;&quot;
        session = self.get_session()
        try:
            query = session.query(StrategyPerformance)
            if strategy_name:
                query = query.filter(
                    StrategyPerformance.strategy_name == strategy_name
                )
            return (
                query.order_by(StrategyPerformance.evaluation_date.desc())
                .limit(20)
                .all()
            )
        except Exception as e:
            logger.error(f&quot;Performans sorgulama hatası: {e}&quot;)
            return []
        finally:
            session.close()


# Global erişim noktası
db = DatabaseManager()</code></pre></div></div></pre><h3>Adım 1.9: FAZ 1 Doğrulama Scripti (tests/test_faz1.py)</h3><pre><div class="not-prose my-0 flex w-full flex-col overflow-clip border border-border text-text-primary rounded-lg not-prose relative" data-code-block="true"><div class="border-border flex items-center justify-between border-b px-4 py-2"><div class="flex items-center gap-2"><svg width="14" stroke-width="1.5" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-text-secondary"><path d="M9.00001 21L8.00001 21C6.89544 21 6.00001 20.1057 6.00001 19.0011C6.00001 17.4501 6.00001 15.3443 6 14C6 13 4.5 12 4.5 12C4.5 12 6.00001 11 6.00001 10C6.00001 8.827 6.00001 6.62207 6.00001 4.99914C6.00001 3.89457 6.89544 3 8.00001 3L9.00001 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 21L16 21C17.1046 21 18 20.1057 18 19.0011C18 17.4501 18 15.3443 18 14C18 13 19.5 12 19.5 12C19.5 12 18 11 18 10C18 8.827 18 6.62207 18 4.99914C18 3.89457 17.1046 3 16 3L15 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><span class="text-text-secondary text-sm font-medium">Python</span></div><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring ring-offset-2 focus-visible:ring-offset-surface-primary disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 text-sm text-interactive-active hover:text-interactive-normal active:text-text-tertiary font-normal relative rounded-lg p-[6px]" type="button" data-state="closed" data-slot="tooltip-trigger"><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-interactive-positive absolute inset-0 m-auto rotate-90 opacity-0 transition-all duration-300"><path d="M5 1