h d="M5 13L9 17L19 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="absolute inset-0 m-auto opacity-100 transition-opacity duration-300"><path d="M19.4 20H9.6C9.26863 20 9 19.7314 9 19.4V9.6C9 9.26863 9.26863 9 9.6 9H19.4C19.7314 9 20 9.26863 20 9.6V19.4C20 19.7314 19.7314 20 19.4 20Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 9V4.6C15 4.26863 14.7314 4 14.4 4H4.6C4.26863 4 4 4.26863 4 4.6V14.4C4 14.7314 4.26863 15 4.6 15H9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg></button></div><div class="code-block_container__lbMX4"><pre class="m-0 whitespace-pre-wrap rounded-none px-4 py-3 font-mono text-[#24292e] dark:text-[#e1e4e8]"><code class="text-[11px] leading-normal sm:text-[13px]"># config/settings.py
&quot;&quot;&quot;
Merkezi yapılandırma yükleyici.
Tüm .env ve .yaml dosyalarını okuyarak sisteme sunar.
&quot;&quot;&quot;

import os
import yaml
from pathlib import Path
from dotenv import load_dotenv
from loguru import logger


# Proje kök dizini
BASE_DIR = Path(__file__).resolve().parent.parent

# .env dosyasını yükle
env_path = BASE_DIR / &quot;config&quot; / &quot;api_keys.env&quot;
load_dotenv(dotenv_path=env_path)


class Settings:
    &quot;&quot;&quot;Tüm sistem ayarlarını merkezi olarak yöneten sınıf.&quot;&quot;&quot;

    _instance = None
    _config = None

    def __new__(cls):
        &quot;&quot;&quot;Singleton pattern - tek bir Settings nesnesi olsun.&quot;&quot;&quot;
        if cls._instance is None:
            cls._instance = super().__new__(cls)
            cls._instance._load_config()
        return cls._instance

    def _load_config(self):
        &quot;&quot;&quot;YAML yapılandırma dosyasını yükler.&quot;&quot;&quot;
        config_path = BASE_DIR / &quot;config&quot; / &quot;agents_config.yaml&quot;
        try:
            with open(config_path, &quot;r&quot;, encoding=&quot;utf-8&quot;) as f:
                self._config = yaml.safe_load(f)
            logger.info(f&quot;Yapılandırma yüklendi: {config_path}&quot;)
        except FileNotFoundError:
            logger.error(f&quot;Yapılandırma dosyası bulunamadı: {config_path}&quot;)
            self._config = {}
        except yaml.YAMLError as e:
            logger.error(f&quot;YAML parse hatası: {e}&quot;)
            self._config = {}

    # --- API Anahtarları (.env&#x27;den) ---
    @property
    def telegram_bot_token(self) -&gt; str:
        return os.getenv(&quot;TELEGRAM_BOT_TOKEN&quot;, &quot;&quot;)

    @property
    def telegram_chat_id(self) -&gt; str:
        return os.getenv(&quot;TELEGRAM_CHAT_ID&quot;, &quot;&quot;)

    @property
    def gemini_api_key(self) -&gt; str:
        return os.getenv(&quot;GEMINI_API_KEY&quot;, &quot;&quot;)

    @property
    def groq_api_key(self) -&gt; str:
        return os.getenv(&quot;GROQ_API_KEY&quot;, &quot;&quot;)

    @property
    def db_host(self) -&gt; str:
        return os.getenv(&quot;DB_HOST&quot;, &quot;localhost&quot;)

    @property
    def db_port(self) -&gt; int:
        return int(os.getenv(&quot;DB_PORT&quot;, &quot;5432&quot;))

    @property
    def db_name(self) -&gt; str:
        return os.getenv(&quot;DB_NAME&quot;, &quot;trading_ai&quot;)

    @property
    def db_user(self) -&gt; str:
        return os.getenv(&quot;DB_USER&quot;, &quot;&quot;)

    @property
    def db_password(self) -&gt; str:
        return os.getenv(&quot;DB_PASSWORD&quot;, &quot;&quot;)

    @property
    def database_url(self) -&gt; str:
        &quot;&quot;&quot;SQLAlchemy uyumlu bağlantı dizesi.&quot;&quot;&quot;
        return (
            f&quot;postgresql://{self.db_user}:{self.db_password}&quot;
            f&quot;@{self.db_host}:{self.db_port}/{self.db_name}&quot;
        )

    # --- YAML&#x27;dan gelen ayarlar ---
    @property
    def system_config(self) -&gt; dict:
        return self._config.get(&quot;system&quot;, {})

    @property
    def schedule_config(self) -&gt; dict:
        return self._config.get(&quot;schedule&quot;, {})

    @property
    def agents_config(self) -&gt; dict:
        return self._config.get(&quot;agents&quot;, {})

    @property
    def models_config(self) -&gt; dict:
        return self._config.get(&quot;models&quot;, {})

    @property
    def scanner_config(self) -&gt; dict:
        return self._config.get(&quot;scanner&quot;, {})

    def get_agent_config(self, agent_name: str) -&gt; dict:
        &quot;&quot;&quot;Belirli bir agent&#x27;in yapılandırmasını döndürür.&quot;&quot;&quot;
        return self.agents_config.get(agent_name, {})

    def get_model_config(self, model_name: str) -&gt; dict:
        &quot;&quot;&quot;Belirli bir modelin yapılandırmasını döndürür.&quot;&quot;&quot;
        return self.models_config.get(model_name, {})

    def validate(self) -&gt; dict:
        &quot;&quot;&quot;Tüm kritik ayarların mevcut olup olmadığını kontrol eder.&quot;&quot;&quot;
        issues = []

        if not self.telegram_bot_token:
            issues.append(&quot;TELEGRAM_BOT_TOKEN eksik&quot;)
        if not self.gemini_api_key:
            issues.append(&quot;GEMINI_API_KEY eksik&quot;)
        if not self.groq_api_key:
            issues.append(&quot;GROQ_API_KEY eksik (fallback çalışmayacak)&quot;)
        if not self.db_user:
            issues.append(&quot;DB_USER eksik&quot;)
        if not self._config:
            issues.append(&quot;agents_config.yaml yüklenemedi&quot;)

        status = &quot;OK&quot; if not issues else &quot;SORUNLU&quot;
        return {
            &quot;status&quot;: status,
            &quot;issues&quot;: issues,
            &quot;agents_loaded&quot;: len(self.agents_config),
            &quot;models_loaded&quot;: len(self.models_config),
        }


# Global erişim noktası
settings = Settings()</code></pre></div></div></pre><h3>Adım 1.7: Loglama Yapılandırması (config/logging_config.py)</h3><pre><div class="not-prose my-0 flex w-full flex-col overflow-clip border border-border text-text-primary rounded-lg not-prose relative" data-code-block="true"><div class="border-border flex items-center justify-between border-b px-4 py-2"><div class="flex items-center gap-2"><svg width="14" stroke-width="1.5" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-text-secondary"><path d="M9.00001 21L8.00001 21C6.89544 21 6.00001 20.1057 6.00001 19.0011C6.00001 17.4501 6.00001 15.3443 6 14C6 13 4.5 12 4.5 12C4.5 12 6.00001 11 6.00001 10C6.00001 8.827 6.00001 6.62207 6.00001 4.99914C6.00001 3.89457 6.89544 3 8.00001 3L9.00001 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 21L16 21C17.1046 21 18 20.1057 18 19.0011C18 17.4501 18 15.3443 18 14C18 13 19.5 12 19.5 12C19.5 12 18 11 18 10C18 8.827 18 6.62207 18 4.99914C18 3.89457 17.1046 3 16 3L15 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><span class="text-text-secondary text-sm font-medium">Python</span></div><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring ring-offset-2 focus-visible:ring-offset-surface-primary disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 text-sm text-interactive-active hover:text-interactive-normal active:text-text-tertiary font-normal relative rounded-lg p-[6px]" type="button" data-state="closed" data-slot="tooltip-trigger"><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-interactive-positive absolute inset-0 m-auto rotate-90 opacity-0 transition-all duration-300"><path d="M5 13L9 17L19 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="absolute inset-0 m-auto opacity-100 transition-opacity duration-300"><path d="M19.4 20H9.6C9.26863 20 9 19.7314 9 19.4V9.6C9 9.26863 9.26863 9 9.6 9H19.4C19.7314 9 20 9.26863 20 9.6V19.4C20 19.7314 19.7314 20 19.4 20Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 9V4.6C15 4.26863 14.7314 4 14.4 4H4.6C4.26863 4 4 4.26863 4 4.6V14.4C4 14.7314 4.26863 15 4.6 15H9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg></button></div><div class="code-block_container__lbMX4"><pre class="m-0 whitespace-pre-wrap rounded-none px-4 py-3 font-mono text-[#24292e] dark:text-[#e1e4e8]"><code class="text-[11px] leading-normal sm:text-[13px]"># config/logging_config.py
&quot;&quot;&quot;
Loguru tabanlı merkezi loglama yapılandırması.
Tüm modüller bu yapılandırmayı kullanır.
&quot;&quot;&quot;

import sys
from pathlib import Path
from loguru import logger

# Proje kök dizini
BASE_DIR = Path(__file__).resolve().parent.parent
LOG_DIR = BASE_DIR / &quot;logs&quot;
LOG_DIR.mkdir(exist_ok=True)


def setup_logging():
    &quot;&quot;&quot;Loglama sistemini başlatır.&quot;&quot;&quot;

    # Varsayılan loguru handler&#x27;ını kaldır
    logger.remove()

    # Konsol çıktısı - renkli ve okunabilir
    logger.add(
        sys.stdout,
        format=(
            &quot;&lt;green&gt;{time:YYYY-MM-DD HH:mm:ss}&lt;/green&gt; | &quot;
            &quot;&lt;level&gt;{level: &lt;8}&lt;/level&gt; | &quot;
            &quot;&lt;cyan&gt;{name}&lt;/cyan&gt;:&lt;cyan&gt;{function}&lt;/cyan&gt;:&lt;cyan&gt;{line}&lt;/cyan&gt; | &quot;
            &quot;&lt;level&gt;{message}&lt;/level&gt;&quot;
        ),
        level=&quot;INFO&quot;,
        colorize=True,
    )

    # Genel log dosyası - her şey yazılır
    logger.add(
        LOG_DIR / &quot;system_{time:YYYY-MM-DD}.log&quot;,
        format=&quot;{time:YYYY-MM-DD HH:mm:ss} | {level: &lt;8} | {name}:{function}:{line} | {message}&quot;,
        level=&quot;DEBUG&quot;,
        rotation=&quot;00:00&quot;,  # Her gece yeni dosya
        retention=&quot;30 days&quot;,  # 30 gün tut
        compression=&quot;zip&quot;,
        encoding=&quot;utf-8&quot;,
    )

    # Hata log dosyası - sadece WARNING ve üstü
    logger.add(
