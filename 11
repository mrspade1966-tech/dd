"none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-interactive-positive absolute inset-0 m-auto rotate-90 opacity-0 transition-all duration-300"><path d="M5 13L9 17L19 7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="absolute inset-0 m-auto opacity-100 transition-opacity duration-300"><path d="M19.4 20H9.6C9.26863 20 9 19.7314 9 19.4V9.6C9 9.26863 9.26863 9 9.6 9H19.4C19.7314 9 20 9.26863 20 9.6V19.4C20 19.7314 19.7314 20 19.4 20Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 9V4.6C15 4.26863 14.7314 4 14.4 4H4.6C4.26863 4 4 4.26863 4 4.6V14.4C4 14.7314 4.26863 15 4.6 15H9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg></button></div><div class="code-block_container__lbMX4"><pre class="m-0 whitespace-pre-wrap rounded-none px-4 py-3 font-mono text-[#24292e] dark:text-[#e1e4e8]"><code class="text-[11px] leading-normal sm:text-[13px]">-- 1. FİYAT CACHE (bot.py&#x27;den taşınıyor, aynı mantık)
CREATE TABLE price_cache (
    ticker      TEXT PRIMARY KEY,
    fetched_at  DATE NOT NULL,
    data        TEXT NOT NULL
);

-- 2. WATCHLIST (bot.py&#x27;den taşınıyor)
CREATE TABLE watchlist (
    chat_id     TEXT NOT NULL,
    ticker      TEXT NOT NULL,
    added_at    TIMESTAMP DEFAULT NOW(),
    PRIMARY KEY (chat_id, ticker)
);

-- 3. EMA OPTİMİZASYON (bot.py&#x27;den taşınıyor)
CREATE TABLE ema_settings (
    ticker      TEXT PRIMARY KEY,
    daily_fast  INT DEFAULT 9,
    daily_slow  INT DEFAULT 21,
    weekly_fast INT DEFAULT 9,
    weekly_slow INT DEFAULT 21,
    updated_at  TIMESTAMP DEFAULT NOW()
);

-- 4. TARAMA SONUÇLARI (YENİ - öğrenme için kritik)
CREATE TABLE scan_results (
    id              SERIAL PRIMARY KEY,
    scan_date       DATE NOT NULL,
    chat_id         TEXT NOT NULL,
    strategy_code   TEXT NOT NULL,
    ticker          TEXT NOT NULL,
    price           FLOAT,
    rsi             FLOAT,
    rel_vol         FLOAT,
    composite       FLOAT,
    ai_comment      TEXT,
    -- Sonuç takibi (başta NULL, sonra doldurulur)
    ret_1d          FLOAT,
    ret_5d          FLOAT,
    ret_21d         FLOAT,
    outcome_filled  BOOLEAN DEFAULT FALSE,
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 5. TRADE KİTABI (bot.py&#x27;den taşınıyor + genişletiliyor)
CREATE TABLE trades (
    id              SERIAL PRIMARY KEY,
    chat_id         TEXT NOT NULL,
    ticker          TEXT NOT NULL,
    direction       TEXT NOT NULL,  -- BUY / SELL
    price           FLOAT NOT NULL,
    quantity        FLOAT NOT NULL,
    total           FLOAT NOT NULL,
    reason          TEXT,           -- Kullanıcının neden aldığı
    strategy_ref    TEXT,           -- Hangi strateji sinyali verdi
    trade_date      TIMESTAMP DEFAULT NOW(),
    -- Satış için
    buy_price       FLOAT,          -- Eşleşen alış fiyatı
    pnl_tl          FLOAT,
    pnl_pct         FLOAT,
    hold_days       INT,
    ai_review       TEXT,           -- AI&#x27;ın satış yorumu
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 6. AÇIK POZİSYONLAR (bot.py&#x27;den taşınıyor)
CREATE TABLE open_positions (
    chat_id         TEXT NOT NULL,
    ticker          TEXT PRIMARY KEY,
    avg_price       FLOAT NOT NULL,
    quantity        FLOAT NOT NULL,
    reason          TEXT,
    opened_at       TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);

-- 7. AGENT KARARLARI (YENİ - hafıza)
CREATE TABLE agent_decisions (
    id              SERIAL PRIMARY KEY,
    agent_name      TEXT NOT NULL,
    decision_type   TEXT NOT NULL,
    context         JSONB,
    decision        TEXT NOT NULL,
    confidence      FLOAT,
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 8. PİYASA BAĞLAMI (YENİ - dinamik skill için)
CREATE TABLE market_context (
    id              SERIAL PRIMARY KEY,
    context_date    DATE UNIQUE NOT NULL,
    regime          TEXT,
    xu100_change    FLOAT,
    usdtry          FLOAT,
    top_sectors     JSONB,
    key_news        TEXT,
    created_at      TIMESTAMP DEFAULT NOW()
);

-- 9. ÖĞRENİLEN DERSLER (YENİ - strategy agent için)
CREATE TABLE lessons (
    id              SERIAL PRIMARY KEY,
    lesson_date     DATE NOT NULL,
    source          TEXT,       -- hangi agent/strateji
    category        TEXT,       -- PATTERN, STRATEGY, RISK
    lesson          TEXT NOT NULL,
    evidence        JSONB,
    importance      INT DEFAULT 5,
    is_active       BOOLEAN DEFAULT TRUE,
    created_at      TIMESTAMP DEFAULT NOW()
);</code></pre></div></div></pre><hr/><h2>🤖 Agent Skill Dosyaları (Yazacağım şeyler)</h2><pre><div class="not-prose my-0 flex w-full flex-col overflow-clip border border-border text-text-primary rounded-lg not-prose relative" data-code-block="true"><div class="border-border flex items-center justify-between border-b px-4 py-2"><div class="flex items-center gap-2"><svg width="14" stroke-width="1.5" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-text-secondary"><path d="M9.00001 21L8.00001 21C6.89544 21 6.00001 20.1057 6.00001 19.0011C6.00001 17.4501 6.00001 15.3443 6 14C6 13 4.5 12 4.5 12C4.5 12 6.00001 11 6.00001 10C6.00001 8.827 6.00001 6.62207 6.00001 4.99914C6.00001 3.89457 6.89544 3 8.00001 3L9.00001 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 21L16 21C17.1046 21 18 20.1057 18 19.0011C18 17.4501 18 15.3443 18 14C18 13 19.5 12 19.5 12C19.5 12 18 11 18 10C18 8.827 18 6.62207 18 4.99914C18 3.89457 17.1046 3 16 3L15 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg><span class="text-text-secondary text-sm font-medium">text</span></div><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring ring-offset-2 focus-visible:ring-offset-surface-primary disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 text-sm text-interactive-active hover:text-interactive-normal active:text-text-tertiary font-normal relative rounded-lg p-[6px]" type="button" data-state="closed" data-slot="tooltip-trigger"><svg width="16" height="16" stroke-width="1.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" color="currentColor" class="text-interactive-positive absolute inset-0 m-auto rotate-90 opacity-0 transition-all duration-300"><path d="M5 13L9 17L19 7" stroke="currentC